generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN_GERAL
  ADMIN_REDE
  ADMIN_FINANCEIRO
  DONO_LOJA
  GERENTE_LOJA
  VENDEDOR
  TECNICO
}

enum StatusPedidoCompra {
  PENDENTE
  APROVADO
  CONFIRMADO
  CANCELADO
}

enum TipoProduto {
  MOTO
  PECA
}

enum StatusUnidade {
  ESTOQUE
  VENDIDA
  MANUTENCAO
  RESERVADA
}

enum StatusOS {
  ORCAMENTO
  EM_EXECUCAO
  EXECUTADA
}

enum TipoVenda {
  VENDA
  ORCAMENTO
}

enum FormaPagamento {
  PIX
  DINHEIRO
  CARTAO
  CARTAO_DEBITO
  CARTAO_CREDITO
  FINANCIAMENTO
}

enum StatusTransferencia {
  SOLICITADA
  APROVADA
  REJEITADA
  CONCLUIDA
}

enum CategoriaConta {
  LUZ
  AGUA
  GAS
  INTERNET
  ALUGUEL
  IPTU
  CONDOMINIO
  FORNECEDORES
  OUTROS
}

enum NaturezaFinanceira {
  RECEITA
  DESPESA
  AMBOS
}

enum OrigemContaPagar {
  COMPRA
  AVULSA
}

enum StatusLancamento {
  ABERTO
  PARCIAL
  LIQUIDADO
  CANCELADO
}

enum PeriodoComissao {
  SEMANAL
  QUINZENAL
  MENSAL
}

enum RecorrenciaConta {
  SEMANAL
  QUINZENAL
  MENSAL
  SEMESTRAL
  ANUAL
}

model Grupo {
  id        Int      @id @default(autoincrement())
  nome      String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  lojas     Loja[]
  usuarios  User[]
}

model Loja {
  id              Int      @id @default(autoincrement())
  cnpj            String   @unique
  razaoSocial     String
  nomeFantasia    String?
  endereco        String?
  telefone        String?
  email           String?
  ativo           Boolean  @default(true)
  grupoId         Int
  comissaoMoto    Decimal  @db.Decimal(5, 2) @default(1.0)
  comissaoPecas   Decimal  @db.Decimal(5, 2) @default(3.0)
  comissaoServico Decimal  @db.Decimal(5, 2) @default(10.0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  grupo           Grupo    @relation(fields: [grupoId], references: [id])
  usuarios     User[]
  estoques     Estoque[]
  unidades     UnidadeFisica[]
  vendas       Venda[]
  ordensServico OrdemServico[]
  caixa        Caixa[]
  contasPagar  ContaPagar[]
  contasReceber ContaReceber[]
  transferenciasOrigem  Transferencia[] @relation("TransferenciaOrigem")
  transferenciasDestino Transferencia[] @relation("TransferenciaDestino")
  logsEstoque           LogEstoque[]
  clientes              Cliente[]
  pedidosCompra         PedidoCompra[]
  auditoriaEstoque      AuditoriaEstoque[]
  pagamentos            Pagamento[]
  recebimentos          Recebimento[]
}

model User {
  id                 Int      @id @default(autoincrement())
  nome               String
  email              String   @unique
  senha              String
  role               Role
  ativo              Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  grupoId            Int?
  lojaId             Int?
  cpf                String?
  telefone           String?
  banco              String?
  agencia            String?
  conta              String?
  tipoConta          String?
  chavePix           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          Int?
  
  grupo       Grupo?         @relation(fields: [grupoId], references: [id])
  loja        Loja?          @relation(fields: [lojaId], references: [id])
  vendas      Venda[]        @relation("VendaVendedor")
  comissoes   Comissao[]
  logs        LogAuditoria[]
  logsEstoque LogEstoque[]
  logsConfiguracao LogConfiguracao[]
  pedidosCompraConfirmados PedidoCompra[] @relation("PedidoConfirmadoPor")
  auditoriaEstoque AuditoriaEstoque[]
}

model Produto {
  id              Int         @id @default(autoincrement())
  codigo          String      @unique @default(cuid())
  nome            String
  tipo            TipoProduto
  custo           Decimal     @db.Decimal(10, 2)
  percentualLucro Decimal     @db.Decimal(5, 2)
  preco           Decimal     @db.Decimal(10, 2)
  ativo           Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  createdBy       Int?
  
  estoques        Estoque[]
  unidades        UnidadeFisica[]
  itensVenda      ItemVenda[]
  itensOS         ItemOS[]
  logsEstoque     LogEstoque[]
  itensPedidoCompra ItemPedidoCompra[]
  auditoriaEstoque  AuditoriaEstoque[]
}

model Servico {
  id        Int      @id @default(autoincrement())
  nome      String
  preco     Decimal  @db.Decimal(10, 2)
  duracao   Int?     // em minutos, null se fixo
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int?
  
  itensVenda ItemVenda[]
  itensOS    ItemOS[]
}

model UnidadeFisica {
  id          Int          @id @default(autoincrement())
  produtoId   Int
  cor         String?
  chassi      String?
  codigoMotor String?
  ano         Int?
  numeroSerie String?
  status      StatusUnidade @default(ESTOQUE)
  lojaId      Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   Int?
  
  produto     Produto      @relation(fields: [produtoId], references: [id])
  loja        Loja         @relation(fields: [lojaId], references: [id])
  itensVenda  ItemVenda[]
  ordensServico OrdemServico[]
  garantias   Garantia[]
  revisoes    Revisao[]
}

model Estoque {
  id            Int      @id @default(autoincrement())
  produtoId     Int
  lojaId        Int
  quantidade    Int      @default(0)
  estoqueMinimo Int      @default(0)
  estoqueMaximo Int      @default(0)
  custoMedio    Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  produto       Produto  @relation(fields: [produtoId], references: [id])
  loja          Loja     @relation(fields: [lojaId], references: [id])
  
  @@unique([produtoId, lojaId])
}

model Transferencia {
  id             Int                @id @default(autoincrement())
  produtoId      Int
  lojaOrigemId   Int
  lojaDestinoId  Int
  quantidade     Int
  status         StatusTransferencia @default(SOLICITADA)
  solicitadoPor  Int
  aprovadoPor    Int?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  
  lojaOrigem     Loja               @relation("TransferenciaOrigem", fields: [lojaOrigemId], references: [id])
  lojaDestino    Loja               @relation("TransferenciaDestino", fields: [lojaDestinoId], references: [id])
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nome      String
  cpfCnpj   String?
  telefone  String?
  email     String?
  cep       String?
  logradouro String?
  numero     String?
  complemento String?
  bairro    String?
  cidade    String?
  estado    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int?
  lojaId    Int?
  
  loja      Loja?    @relation(fields: [lojaId], references: [id])
  vendas    Venda[]
  ordensServico OrdemServico[]
  garantias Garantia[]
}

model Venda {
  id              Int           @id @default(autoincrement())
  tipo            TipoVenda
  clienteId       Int
  vendedorId      Int
  lojaId          Int
  formaPagamento  FormaPagamento
  desconto        Decimal       @db.Decimal(10, 2) @default(0)
  valorTotal      Decimal       @db.Decimal(10, 2)
  valorBruto      Decimal?      @db.Decimal(10, 2)
  parcelas        Int?
  confirmadaFinanceiro Boolean  @default(false)
  deletedAt       DateTime?
  deletedBy       Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       Int?
  
  cliente         Cliente       @relation(fields: [clienteId], references: [id])
  vendedor        User          @relation("VendaVendedor", fields: [vendedorId], references: [id])
  loja            Loja          @relation(fields: [lojaId], references: [id])
  itens           ItemVenda[]
  comissoes       Comissao[]
  garantias       Garantia[]
}

model ItemVenda {
  id              Int          @id @default(autoincrement())
  vendaId         Int
  produtoId       Int?
  servicoId       Int?
  unidadeFisicaId Int?
  quantidade      Int          @default(1)
  precoUnitario   Decimal      @db.Decimal(10, 2)
  desconto        Decimal      @db.Decimal(5, 2) @default(0)
  
  venda           Venda        @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  produto         Produto?     @relation(fields: [produtoId], references: [id])
  servico         Servico?     @relation(fields: [servicoId], references: [id])
  unidadeFisica   UnidadeFisica? @relation(fields: [unidadeFisicaId], references: [id])
}

model OrdemServico {
  id              Int        @id @default(autoincrement())
  numero          String     @unique @default(cuid())
  clienteId       Int
  unidadeFisicaId Int?
  motoDescricao   String?
  tecnico         String?
  tipo            String     @default("OS")
  status          StatusOS   @default(ORCAMENTO)
  desconto        Decimal    @db.Decimal(5, 2) @default(0)
  valorTotal      Decimal    @db.Decimal(10, 2)
  valorBruto      Decimal?   @db.Decimal(10, 2)
  garantiaMeses   Int        @default(3)
  observacoes     String?
  lojaId          Int
  confirmadaFinanceiro Boolean @default(false)
  deletedAt       DateTime?
  deletedBy       Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  createdBy       Int?
  
  cliente         Cliente    @relation(fields: [clienteId], references: [id])
  unidadeFisica   UnidadeFisica? @relation(fields: [unidadeFisicaId], references: [id])
  loja            Loja       @relation(fields: [lojaId], references: [id])
  itens           ItemOS[]
  comissoes       Comissao[]
}

model ItemOS {
  id              Int          @id @default(autoincrement())
  ordemServicoId  Int
  produtoId       Int?
  servicoId       Int?
  quantidade      Int          @default(1)
  precoUnitario   Decimal      @db.Decimal(10, 2)
  desconto        Decimal      @db.Decimal(5, 2) @default(0)
  
  ordemServico    OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  produto         Produto?     @relation(fields: [produtoId], references: [id])
  servico         Servico?     @relation(fields: [servicoId], references: [id])
}

model Garantia {
  id              Int            @id @default(autoincrement())
  unidadeFisicaId Int?
  clienteId       Int?
  vendaId         Int?
  tipoGarantia    String         // geral, motor, modulo, bateria
  meses           Int
  dataInicio      DateTime
  dataFim         DateTime
  ativa           Boolean        @default(true)
  revisaoFeita    Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  unidadeFisica   UnidadeFisica? @relation(fields: [unidadeFisicaId], references: [id])
  cliente         Cliente?       @relation(fields: [clienteId], references: [id])
  venda           Venda?         @relation(fields: [vendaId], references: [id])
}

model Revisao {
  id              Int           @id @default(autoincrement())
  unidadeFisicaId Int
  numero          Int           // 1ª, 2ª, 3ª...
  dataAgendada    DateTime
  dataRealizada   DateTime?
  gratuita        Boolean       @default(false)
  valor           Decimal?      @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  unidadeFisica   UnidadeFisica @relation(fields: [unidadeFisicaId], references: [id])
}

model Caixa {
  id              Int           @id @default(autoincrement())
  lojaId          Int
  data            DateTime      @default(now())
  tipo            String        // entrada, saida
  descricao       String
  valor           Decimal       @db.Decimal(10, 2)
  formaPagamento  FormaPagamento?
  referencia      String?       // venda_id, os_id, conta_id
  createdAt       DateTime      @default(now())
  
  loja            Loja          @relation(fields: [lojaId], references: [id])
}

model ContaPagar {
  id                    Int                @id @default(autoincrement())
  lojaId                Int
  origem                OrigemContaPagar   @default(AVULSA)
  pedidoCompraId        Int?
  categoriaLegacy       CategoriaConta?
  categoriaId           Int?
  departamentoId        Int?
  descricao             String?
  fornecedor            String?
  centroCusto           String?
  documento             String?
  observacoes           String?
  valor                 Decimal            @db.Decimal(10, 2)
  valorPago             Decimal            @db.Decimal(10, 2) @default(0)
  vencimento            DateTime
  numeroParcelas        Int                @default(1)
  status                StatusLancamento   @default(ABERTO)
  recorrente            Boolean            @default(false)
  recorrencia           RecorrenciaConta?
  pago                  Boolean            @default(false)
  dataPago              DateTime?
  deletedAt             DateTime?
  deletedBy             Int?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  createdBy             Int?

  loja                  Loja               @relation(fields: [lojaId], references: [id])
  categoria             CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])
  departamento          Departamento?      @relation(fields: [departamentoId], references: [id])
  pedidoCompra          PedidoCompra?      @relation(fields: [pedidoCompraId], references: [id])
  parcelas              ParcelaContaPagar[]
  pagamentos            Pagamento[]
}

model LogAuditoria {
  id          Int      @id @default(autoincrement())
  usuarioId   Int
  acao        String
  entidade    String
  entidadeId  Int
  dados       String?
  createdAt   DateTime @default(now())
  
  usuario     User     @relation(fields: [usuarioId], references: [id])
}

model Comissao {
  id              Int           @id @default(autoincrement())
  usuarioId       Int
  vendaId         Int?
  ordemServicoId  Int?
  tipo            String        // vendedor, tecnico
  valor           Decimal       @db.Decimal(10, 2)
  periodo         PeriodoComissao
  pago            Boolean       @default(false)
  dataPago        DateTime?
  createdAt       DateTime      @default(now())
  
  usuario         User          @relation(fields: [usuarioId], references: [id])
  venda           Venda?        @relation(fields: [vendaId], references: [id])
  ordemServico    OrdemServico? @relation(fields: [ordemServicoId], references: [id])
}

model ContaReceber {
  id             Int               @id @default(autoincrement())
  lojaId         Int
  clienteId      Int?
  vendaId        Int?
  categoriaId    Int?
  departamentoId Int?
  descricao      String
  observacoes    String?
  valor          Decimal           @db.Decimal(10, 2)
  valorRecebido  Decimal           @db.Decimal(10, 2) @default(0)
  vencimento     DateTime
  numeroParcelas Int               @default(1)
  status         StatusLancamento  @default(ABERTO)
  recorrente     Boolean           @default(false)
  recorrencia    RecorrenciaConta?
  pago           Boolean           @default(false)
  dataPago       DateTime?
  deletedAt      DateTime?
  deletedBy      Int?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  createdBy      Int?

  loja           Loja              @relation(fields: [lojaId], references: [id])
  categoria      CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])
  departamento   Departamento?     @relation(fields: [departamentoId], references: [id])
  parcelas       ParcelaContaReceber[]
  recebimentos   Recebimento[]
}

model Configuracao {
  id                    Int     @id @default(autoincrement())
  comissaoVendedorMoto  Decimal @db.Decimal(5, 2) @default(1)
  comissaoTecnico       Decimal @db.Decimal(5, 2) @default(25)
  comissaoPecaHabilitada Boolean @default(false)
  periodoComissao       PeriodoComissao @default(MENSAL)
  descontoMaxMoto       Decimal @db.Decimal(5, 2) @default(3.5)
  descontoMaxPeca       Decimal @db.Decimal(5, 2) @default(10)
  descontoMaxServico    Decimal @db.Decimal(5, 2) @default(10)
  descontoMaxOS         Decimal @db.Decimal(5, 2) @default(10)
  lucroMoto             Decimal @db.Decimal(5, 2) @default(30)
  lucroPeca             Decimal @db.Decimal(5, 2) @default(30)
}

enum TipoMovimentoEstoque {
  ENTRADA
  SAIDA
  AJUSTE
  TRANSFERENCIA
  VENDA
  OS
  PEDIDO_COMPRA
  DEVOLUCAO
  PERDA
  AVARIA
  RESERVA
}

model LogEstoque {
  id          Int                  @id @default(autoincrement())
  tipo        TipoMovimentoEstoque
  origem      String               // VENDA, OS, AJUSTE, TRANSFERENCIA
  origemId    Int?
  produtoId   Int
  lojaId      Int
  quantidade  Int
  quantidadeAnterior Int
  quantidadeNova     Int
  usuarioId   Int
  createdAt   DateTime             @default(now())
  
  produto     Produto              @relation(fields: [produtoId], references: [id])
  loja        Loja                 @relation(fields: [lojaId], references: [id])
  usuario     User                 @relation(fields: [usuarioId], references: [id])
}

model LogConfiguracao {
  id          Int      @id @default(autoincrement())
  campo       String
  valorAnterior String
  valorNovo   String
  usuarioId   Int
  createdAt   DateTime @default(now())
  
  usuario     User     @relation(fields: [usuarioId], references: [id])
}

// ── Pedidos de Compra ─────────────────────────────────────────────────────────

model PedidoCompra {
  id              Int                @id @default(autoincrement())
  lojaId          Int
  fornecedor      String
  numero          String?
  status          StatusPedidoCompra @default(PENDENTE)
  previsaoEntrega DateTime?
  observacoes     String?
  valorTotal      Decimal            @db.Decimal(10, 2) @default(0)
  confirmedAt     DateTime?
  confirmedBy     Int?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       Int?

  loja            Loja               @relation(fields: [lojaId], references: [id])
  confirmadoPor   User?              @relation("PedidoConfirmadoPor", fields: [confirmedBy], references: [id])
  itens           ItemPedidoCompra[]
  contasPagar     ContaPagar[]
}

model ItemPedidoCompra {
  id             Int          @id @default(autoincrement())
  pedidoId       Int
  produtoId      Int
  quantidade     Int
  valorUnitario  Decimal      @db.Decimal(10, 2)
  valorTotal     Decimal      @db.Decimal(10, 2)

  pedido         PedidoCompra @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto        Produto      @relation(fields: [produtoId], references: [id])
}

// ── Auditoria de Estoque ──────────────────────────────────────────────────────

model AuditoriaEstoque {
  id            Int      @id @default(autoincrement())
  lojaId        Int
  usuarioId     Int
  acao          String
  produtoId     Int?
  quantidade    Int?
  custoAnterior Decimal? @db.Decimal(10, 2)
  custoNovo     Decimal? @db.Decimal(10, 2)
  observacao    String?
  referencia    String?
  createdAt     DateTime @default(now())

  loja          Loja     @relation(fields: [lojaId], references: [id])
  usuario       User     @relation(fields: [usuarioId], references: [id])
  produto       Produto? @relation(fields: [produtoId], references: [id])
}

// ── Financeiro: Categorias & Departamentos ────────────────────────────────────

model CategoriaFinanceira {
  id          Int                @id @default(autoincrement())
  nome        String
  natureza    NaturezaFinanceira
  descricao   String?
  ativo       Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  contasPagar    ContaPagar[]
  contasReceber  ContaReceber[]
}

model Departamento {
  id          Int                @id @default(autoincrement())
  nome        String
  natureza    NaturezaFinanceira
  descricao   String?
  ativo       Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  contasPagar    ContaPagar[]
  contasReceber  ContaReceber[]
}

// ── Parcelas ──────────────────────────────────────────────────────────────────

model ParcelaContaPagar {
  id            Int              @id @default(autoincrement())
  contaPagarId  Int
  numero        Int
  valor         Decimal          @db.Decimal(10, 2)
  vencimento    DateTime
  status        StatusLancamento @default(ABERTO)
  dataPago      DateTime?
  valorPago     Decimal?         @db.Decimal(10, 2)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  contaPagar    ContaPagar       @relation(fields: [contaPagarId], references: [id])
  pagamentos    Pagamento[]
}

model ParcelaContaReceber {
  id              Int              @id @default(autoincrement())
  contaReceberId  Int
  numero          Int
  valor           Decimal          @db.Decimal(10, 2)
  vencimento      DateTime
  status          StatusLancamento @default(ABERTO)
  dataPago        DateTime?
  valorRecebido   Decimal?         @db.Decimal(10, 2)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  contaReceber    ContaReceber     @relation(fields: [contaReceberId], references: [id])
  recebimentos    Recebimento[]
}

// ── Movimentos Financeiros ────────────────────────────────────────────────────

model Pagamento {
  id                  Int                @id @default(autoincrement())
  lojaId              Int
  contaPagarId        Int?
  parcelaId           Int?
  valor               Decimal            @db.Decimal(10, 2)
  dataPagamento       DateTime
  formaPagamento      FormaPagamento
  observacoes         String?
  comprovante         String?
  createdAt           DateTime           @default(now())
  createdBy           Int?

  loja                Loja               @relation(fields: [lojaId], references: [id])
  contaPagar          ContaPagar?        @relation(fields: [contaPagarId], references: [id])
  parcela             ParcelaContaPagar? @relation(fields: [parcelaId], references: [id])
}

model Recebimento {
  id                  Int                  @id @default(autoincrement())
  lojaId              Int
  contaReceberId      Int?
  parcelaId           Int?
  valor               Decimal              @db.Decimal(10, 2)
  dataRecebimento     DateTime
  formaPagamento      FormaPagamento
  observacoes         String?
  comprovante         String?
  createdAt           DateTime             @default(now())
  createdBy           Int?

  loja                Loja                 @relation(fields: [lojaId], references: [id])
  contaReceber        ContaReceber?        @relation(fields: [contaReceberId], references: [id])
  parcela             ParcelaContaReceber? @relation(fields: [parcelaId], references: [id])
}
