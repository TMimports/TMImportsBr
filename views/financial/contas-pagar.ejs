<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contas a Pagar - Tecle Motos</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/topbar') %>
      <div class="content">
        <div class="page-header">
          <h1 class="page-title">Contas a Pagar</h1>
          <% if (user.perfil === 'SUPER_ADMIN') { %>
            <button class="btn btn-primary" onclick="openModal('createModal')">
              <i class="fas fa-plus"></i> Nova Conta
            </button>
          <% } %>
        </div>

        <form class="search-bar" method="GET" style="flex-wrap: wrap; gap: 10px;">
          <input type="text" name="search" class="form-control" placeholder="Pesquisar descrição/fornecedor..." value="<%= filters.search || '' %>" style="min-width: 180px;">
          <select name="status" class="form-control" style="min-width: 120px;">
            <option value="">Todos Status</option>
            <option value="PENDENTE" <%= filters.status === 'PENDENTE' ? 'selected' : '' %>>Pendente</option>
            <option value="PAGO" <%= filters.status === 'PAGO' ? 'selected' : '' %>>Pago</option>
            <option value="CANCELADO" <%= filters.status === 'CANCELADO' ? 'selected' : '' %>>Cancelado</option>
          </select>
          <select name="tipo_conta" class="form-control" style="min-width: 120px;">
            <option value="">Todos Tipos</option>
            <option value="FIXA" <%= filters.tipo_conta === 'FIXA' ? 'selected' : '' %>>Fixa</option>
            <option value="VARIAVEL" <%= filters.tipo_conta === 'VARIAVEL' ? 'selected' : '' %>>Variável</option>
            <option value="UNICA" <%= filters.tipo_conta === 'UNICA' ? 'selected' : '' %>>Única</option>
          </select>
          <div style="display: flex; align-items: center; gap: 5px;">
            <label style="color: var(--text-secondary); font-size: 0.85rem;">De:</label>
            <input type="date" name="data_inicio" class="form-control" style="min-width: 140px;" value="<%= filters.periodo ? filters.periodo.split(',')[0] : '' %>">
          </div>
          <div style="display: flex; align-items: center; gap: 5px;">
            <label style="color: var(--text-secondary); font-size: 0.85rem;">Até:</label>
            <input type="date" name="data_fim" class="form-control" style="min-width: 140px;" value="<%= filters.periodo ? filters.periodo.split(',')[1] : '' %>">
          </div>
          <button type="submit" class="btn btn-secondary"><i class="fas fa-search"></i></button>
          <% if (filters.search || filters.status || filters.tipo_conta || filters.periodo) { %>
            <a href="/financeiro/contas-pagar" class="btn btn-warning" title="Limpar filtros"><i class="fas fa-times"></i></a>
          <% } %>
        </form>

        <div class="card">
          <div class="card-body">
            <div class="table-container">
              <table>
                <thead>
                  <tr>
                    <th>Descrição</th>
                    <th>Valor</th>
                    <th>Vencimento</th>
                    <th>Fornecedor</th>
                    <th>Categoria</th>
                    <th>Tipo</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (contas.length === 0) { %>
                    <tr><td colspan="8" class="empty-state">Nenhuma conta a pagar</td></tr>
                  <% } else { %>
                    <% contas.forEach(conta => { 
                      const vencida = new Date(conta.data_vencimento) < new Date() && conta.status === 'PENDENTE';
                    %>
                      <tr class="<%= vencida ? 'critical-stock' : '' %>">
                        <td>
                          <strong><%= conta.descricao %></strong>
                          <% if (conta.recorrencia_ativa) { %>
                            <span class="badge badge-info" style="margin-left: 5px;">Recorrente</span>
                          <% } %>
                        </td>
                        <td style="color: var(--danger); font-weight: bold;"><%= formatCurrency(conta.valor) %></td>
                        <td><%= formatDate(conta.data_vencimento) %></td>
                        <td><%= conta.fornecedor || '-' %></td>
                        <td><%= conta.categoria || '-' %></td>
                        <td><span class="badge badge-secondary"><%= conta.tipo_conta %></span></td>
                        <td>
                          <span class="badge badge-<%= conta.status === 'PAGO' ? 'success' : (conta.status === 'PENDENTE' ? 'warning' : 'danger') %>">
                            <%= conta.status %>
                          </span>
                        </td>
                        <td>
                          <div class="actions">
                            <% if (user.perfil === 'SUPER_ADMIN') { %>
                              <button class="btn btn-sm btn-secondary" onclick='openEditModal(<%= JSON.stringify(conta) %>)'>
                                <i class="fas fa-edit"></i>
                              </button>
                              <% if (conta.status !== 'PAGO') { %>
                                <form action="/financeiro/contas-pagar/<%= conta.id %>/baixa" method="POST" style="display:inline;">
                                  <%- include('../partials/csrf') %>
                                  <button type="submit" class="btn btn-sm btn-success" title="Dar Baixa">
                                    <i class="fas fa-check"></i>
                                  </button>
                                </form>
                              <% } %>
                              <form action="/financeiro/contas-pagar/<%= conta.id %>/arquivar" method="POST" style="display:inline;">
                                <%- include('../partials/csrf') %>
                                <button type="submit" class="btn btn-sm btn-warning" title="Arquivar">
                                  <i class="fas fa-archive"></i>
                                </button>
                              </form>
                              <form action="/financeiro/contas-pagar/<%= conta.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Excluir conta?')">
                                <%- include('../partials/csrf') %>
                                <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                              </form>
                            <% } %>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="createModal">
    <div class="modal" style="max-width: 700px;">
      <div class="modal-header">
        <h3 class="modal-title">Nova Conta a Pagar</h3>
        <button class="modal-close" onclick="closeModal('createModal')">&times;</button>
      </div>
      <form action="/financeiro/contas-pagar" method="POST" id="formContaPagar">
        <%- include('../partials/csrf') %>
        <div class="modal-body">
          <div class="form-group">
            <label class="form-label">Descrição *</label>
            <input type="text" name="descricao" id="descricao_base" class="form-control" placeholder="Ex: Conta de Luz, Aluguel..." required>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Valor Base *</label>
              <input type="number" name="valor" id="valor_base" class="form-control" step="0.01" min="0" required>
            </div>
            <div class="form-group">
              <label class="form-label">Data de Vencimento Inicial *</label>
              <input type="date" name="data_vencimento" id="data_base" class="form-control" required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Fornecedor</label>
              <input type="text" name="fornecedor" class="form-control" placeholder="Nome do fornecedor">
            </div>
            <div class="form-group">
              <label class="form-label">Categoria</label>
              <input type="text" name="categoria" class="form-control" placeholder="Ex: Luz, Aluguel, Internet">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Tipo de Conta *</label>
              <select name="tipo_conta" id="tipo_conta" class="form-control" required onchange="toggleRecorrencia(this.value)">
                <option value="UNICA">Única</option>
                <option value="FIXA">Fixa (Mensal)</option>
                <option value="VARIAVEL">Variável</option>
              </select>
            </div>
            <div class="form-group" id="recorrenciaGroup" style="display: none;">
              <label class="form-label">Recorrência</label>
              <div class="checkbox-group">
                <input type="checkbox" name="recorrencia_ativa" id="recorrencia_ativa" onchange="gerarParcelas()">
                <label for="recorrencia_ativa">Gerar parcelas mensais até dezembro</label>
              </div>
            </div>
          </div>
          
          <div id="parcelasContainer" style="display: none; margin-top: 20px;">
            <h4 style="color: var(--accent-color); margin-bottom: 15px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">
              <i class="fas fa-calendar-alt"></i> Parcelas Mensais
            </h4>
            <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 15px;">
              Edite as datas e valores de cada parcela conforme necessário:
            </p>
            <div id="parcelasList" style="max-height: 300px; overflow-y: auto;"></div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeModal('createModal')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="editModal">
    <div class="modal">
      <div class="modal-header">
        <h3 class="modal-title">Editar Conta a Pagar</h3>
        <button class="modal-close" onclick="closeModal('editModal')">&times;</button>
      </div>
      <form id="editForm" method="POST">
        <%- include('../partials/csrf') %>
        <div class="modal-body">
          <div class="form-group">
            <label class="form-label">Descrição</label>
            <input type="text" name="descricao" id="edit_descricao" class="form-control" required>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Valor</label>
              <input type="number" name="valor" id="edit_valor" class="form-control" step="0.01" min="0" required>
            </div>
            <div class="form-group">
              <label class="form-label">Data de Vencimento</label>
              <input type="date" name="data_vencimento" id="edit_vencimento" class="form-control" required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Fornecedor</label>
              <input type="text" name="fornecedor" id="edit_fornecedor" class="form-control">
            </div>
            <div class="form-group">
              <label class="form-label">Categoria</label>
              <input type="text" name="categoria" id="edit_categoria" class="form-control">
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeModal('editModal')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/app.js"></script>
  <script>
    const meses = ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 
                   'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'];
    
    function toggleRecorrencia(tipo) {
      document.getElementById('recorrenciaGroup').style.display = tipo === 'FIXA' ? 'block' : 'none';
      if (tipo !== 'FIXA') {
        document.getElementById('recorrencia_ativa').checked = false;
        document.getElementById('parcelasContainer').style.display = 'none';
        document.getElementById('parcelasList').innerHTML = '';
      }
    }
    
    function gerarParcelas() {
      const checkbox = document.getElementById('recorrencia_ativa');
      const container = document.getElementById('parcelasContainer');
      const lista = document.getElementById('parcelasList');
      
      if (!checkbox.checked) {
        container.style.display = 'none';
        lista.innerHTML = '';
        return;
      }
      
      const dataBase = document.getElementById('data_base').value;
      const valorBase = document.getElementById('valor_base').value || 0;
      
      if (!dataBase) {
        alert('Por favor, selecione a data de vencimento inicial primeiro.');
        checkbox.checked = false;
        return;
      }
      
      const dataInicial = new Date(dataBase + 'T12:00:00');
      const mesInicial = dataInicial.getMonth();
      const anoInicial = dataInicial.getFullYear();
      const diaVencimento = dataInicial.getDate();
      
      const numParcelas = 12 - mesInicial;
      
      lista.innerHTML = '';
      
      for (let i = 0; i < numParcelas; i++) {
        const mesAtual = mesInicial + i;
        const anoAtual = anoInicial;
        
        const ultimoDiaMes = new Date(anoAtual, mesAtual + 1, 0).getDate();
        const diaFinal = Math.min(diaVencimento, ultimoDiaMes);
        
        const dataVenc = new Date(anoAtual, mesAtual, diaFinal);
        const dataFormatada = dataVenc.toISOString().split('T')[0];
        
        const parcelaHtml = `
          <div class="form-row" style="margin-bottom: 10px; padding: 10px; background: var(--card-bg); border-radius: 8px; border-left: 3px solid var(--accent-color);">
            <div style="flex: 0 0 100px; display: flex; align-items: center;">
              <span style="color: var(--accent-color); font-weight: bold;">${i + 1}/${numParcelas}</span>
              <span style="margin-left: 10px; color: var(--text-secondary);">${meses[mesAtual]}</span>
            </div>
            <div class="form-group" style="flex: 1; margin: 0 10px;">
              <input type="date" name="parcelas[${i}][data]" class="form-control" value="${dataFormatada}" style="padding: 8px;">
            </div>
            <div class="form-group" style="flex: 1; margin: 0;">
              <div style="position: relative;">
                <span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text-secondary);">R$</span>
                <input type="number" name="parcelas[${i}][valor]" class="form-control" step="0.01" min="0" value="${valorBase}" style="padding: 8px; padding-left: 35px;">
              </div>
            </div>
          </div>
        `;
        lista.innerHTML += parcelaHtml;
      }
      
      container.style.display = 'block';
    }
    
    document.getElementById('data_base').addEventListener('change', function() {
      if (document.getElementById('recorrencia_ativa').checked) {
        gerarParcelas();
      }
    });
    
    document.getElementById('valor_base').addEventListener('input', function() {
      if (document.getElementById('recorrencia_ativa').checked) {
        const novoValor = this.value;
        document.querySelectorAll('input[name^="parcelas"][name$="[valor]"]').forEach(input => {
          input.value = novoValor;
        });
      }
    });
    
    function openEditModal(conta) {
      document.getElementById('editForm').action = '/financeiro/contas-pagar/' + conta.id + '/update';
      document.getElementById('edit_descricao').value = conta.descricao || '';
      document.getElementById('edit_valor').value = conta.valor || 0;
      document.getElementById('edit_vencimento').value = conta.data_vencimento ? conta.data_vencimento.split('T')[0] : '';
      document.getElementById('edit_fornecedor').value = conta.fornecedor || '';
      document.getElementById('edit_categoria').value = conta.categoria || '';
      openModal('editModal');
    }
  </script>
</body>
</html>
