<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detalhes da Venda #<%= venda.id %> - Tecle Motos</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/topbar') %>
      <div class="content">
        <div class="page-header">
          <h1 class="page-title">
            <i class="fas fa-receipt"></i> Venda #<%= venda.id %>
          </h1>
          <div style="display: flex; gap: 10px; flex-wrap: wrap;">
            <a href="/vendas/<%= venda.id %>/imprimir" class="btn btn-secondary" target="_blank">
              <i class="fas fa-print"></i> Imprimir
            </a>
            <a href="/vendas/<%= venda.id %>/recibo" class="btn btn-info" target="_blank">
              <i class="fas fa-receipt"></i> Recibo
            </a>
            <a href="/vendas" class="btn btn-outline">
              <i class="fas fa-arrow-left"></i> Voltar
            </a>
          </div>
        </div>

        <div class="stats-grid" style="grid-template-columns: repeat(4, 1fr);">
          <div class="stat-card">
            <div class="stat-icon <%= venda.status === 'CONCLUIDA' ? 'green' : (venda.status === 'PENDENTE' ? 'yellow' : (venda.status === 'APROVADA' ? 'blue' : 'red')) %>">
              <i class="fas fa-<%= venda.status === 'CONCLUIDA' ? 'check-circle' : (venda.status === 'PENDENTE' ? 'clock' : (venda.status === 'APROVADA' ? 'thumbs-up' : 'ban')) %>"></i>
            </div>
            <div class="stat-value"><%= venda.status %></div>
            <div class="stat-label">Status</div>
          </div>
          <div class="stat-card highlight">
            <div class="stat-icon orange">
              <i class="fas fa-dollar-sign"></i>
            </div>
            <div class="stat-value"><%= formatCurrency(venda.valor_total) %></div>
            <div class="stat-label">Valor Total</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon blue">
              <i class="fas fa-calendar"></i>
            </div>
            <div class="stat-value"><%= formatDate(venda.data_venda || venda.createdAt) %></div>
            <div class="stat-label">Data da Venda</div>
          </div>
          <div class="stat-card">
            <div class="stat-icon green">
              <i class="fas fa-credit-card"></i>
            </div>
            <div class="stat-value"><%= venda.forma_pagamento || 'N/A' %></div>
            <div class="stat-label">Forma de Pagamento</div>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px;">
          <div class="card">
            <div class="card-header">
              <h3 class="card-title"><i class="fas fa-user"></i> Dados do Cliente</h3>
            </div>
            <div class="card-body">
              <div style="display: grid; gap: 15px;">
                <div>
                  <label style="color: var(--text-secondary); font-size: 0.8rem;">Nome</label>
                  <p style="margin: 5px 0; font-size: 1.1rem;"><strong><%= venda.cliente_nome %></strong></p>
                </div>
                <div>
                  <label style="color: var(--text-secondary); font-size: 0.8rem;">Telefone</label>
                  <p style="margin: 5px 0;"><%= venda.cliente_telefone || 'Não informado' %></p>
                </div>
                <div>
                  <label style="color: var(--text-secondary); font-size: 0.8rem;">Email</label>
                  <p style="margin: 5px 0;"><%= venda.cliente_email || 'Não informado' %></p>
                </div>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="card-header">
              <h3 class="card-title"><i class="fas fa-user-tie"></i> Vendedor & Estoque</h3>
            </div>
            <div class="card-body">
              <div style="display: grid; gap: 15px;">
                <div>
                  <label style="color: var(--text-secondary); font-size: 0.8rem;">Vendedor</label>
                  <p style="margin: 5px 0; font-size: 1.1rem;"><strong><%= venda.vendedor ? venda.vendedor.nome : 'N/A' %></strong></p>
                </div>
                <div>
                  <label style="color: var(--text-secondary); font-size: 0.8rem;">Estoque Consumido</label>
                  <p style="margin: 5px 0;"><%= venda.Estoque ? venda.Estoque.nome_estoque : 'Nenhum' %></p>
                </div>
                <div>
                  <label style="color: var(--text-secondary); font-size: 0.8rem;">Subestoque</label>
                  <p style="margin: 5px 0;"><%= venda.Subestoque ? venda.Subestoque.nome_subestoque : 'Nenhum' %></p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="card" style="margin-top: 20px;">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-shopping-cart"></i> Itens da Venda</h3>
          </div>
          <div class="card-body">
            <div class="table-container">
              <table>
                <thead>
                  <tr>
                    <th>Produto</th>
                    <th>Tipo</th>
                    <th>Cor</th>
                    <th>Quantidade</th>
                    <th>Preço Unitário</th>
                    <th>Subtotal</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (venda.ItemVendas && venda.ItemVendas.length > 0) { %>
                    <% venda.ItemVendas.forEach(item => { %>
                      <tr>
                        <td><strong><%= item.Produto ? (item.Produto.nome_modelo || item.Produto.nome_produto) : 'Produto removido' %></strong></td>
                        <td><span class="badge badge-info"><%= item.Produto ? item.Produto.tipo : '-' %></span></td>
                        <td><%= item.cor_escolhida || (item.Produto ? item.Produto.cor : '-') || '-' %></td>
                        <td><%= item.quantidade %></td>
                        <td><%= formatCurrency(item.preco_unitario) %></td>
                        <td><strong><%= formatCurrency(item.preco_unitario * item.quantidade) %></strong></td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr><td colspan="6" class="empty-state">Nenhum item na venda</td></tr>
                  <% } %>
                </tbody>
                <tfoot>
                  <tr style="background: var(--surface);">
                    <td colspan="4"></td>
                    <td><strong>Desconto:</strong></td>
                    <td><strong style="color: var(--danger);">- <%= formatCurrency(venda.desconto || 0) %></strong></td>
                  </tr>
                  <tr style="background: var(--orange); color: #000;">
                    <td colspan="4"></td>
                    <td><strong>TOTAL:</strong></td>
                    <td><strong><%= formatCurrency(venda.valor_total) %></strong></td>
                  </tr>
                </tfoot>
              </table>
            </div>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px;">
          <% if (chassisVinculados && chassisVinculados.length > 0) { %>
          <div class="card">
            <div class="card-header">
              <h3 class="card-title"><i class="fas fa-barcode"></i> Chassis Vinculados</h3>
            </div>
            <div class="card-body">
              <% chassisVinculados.forEach(chassi => { %>
                <div class="list-item">
                  <div>
                    <strong><%= chassi.numero_chassi %></strong>
                    <div style="font-size: 0.8rem; color: var(--text-secondary);">
                      Motor: <%= chassi.numero_motor || 'N/A' %>
                    </div>
                  </div>
                  <span class="badge badge-success">VENDIDO</span>
                </div>
              <% }) %>
            </div>
          </div>
          <% } %>

          <% if (contaReceber) { %>
          <div class="card">
            <div class="card-header">
              <h3 class="card-title"><i class="fas fa-file-invoice-dollar"></i> Conta a Receber</h3>
            </div>
            <div class="card-body">
              <div style="display: grid; gap: 15px;">
                <div>
                  <label style="color: var(--text-secondary); font-size: 0.8rem;">Valor</label>
                  <p style="margin: 5px 0; font-size: 1.2rem; color: var(--success);"><strong><%= formatCurrency(contaReceber.valor) %></strong></p>
                </div>
                <div>
                  <label style="color: var(--text-secondary); font-size: 0.8rem;">Vencimento</label>
                  <p style="margin: 5px 0;"><%= formatDate(contaReceber.data_vencimento) %></p>
                </div>
                <div>
                  <label style="color: var(--text-secondary); font-size: 0.8rem;">Status</label>
                  <span class="badge badge-<%= contaReceber.status === 'PAGO' ? 'success' : (contaReceber.status === 'ATRASADO' ? 'danger' : 'warning') %>">
                    <%= contaReceber.status %>
                  </span>
                </div>
              </div>
            </div>
          </div>
          <% } %>

          <% if (venda.AnexoVendas && venda.AnexoVendas.length > 0) { %>
          <div class="card">
            <div class="card-header">
              <h3 class="card-title"><i class="fas fa-paperclip"></i> Anexos</h3>
            </div>
            <div class="card-body">
              <% venda.AnexoVendas.forEach(anexo => { %>
                <div class="list-item">
                  <div>
                    <i class="fas fa-file"></i>
                    <a href="/<%= anexo.caminho_arquivo %>" target="_blank" style="color: var(--orange); margin-left: 10px;">
                      <%= anexo.nome_arquivo %>
                    </a>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
          <% } %>
        </div>

        <div class="card" style="margin-top: 20px;">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-history"></i> Histórico</h3>
          </div>
          <div class="card-body">
            <div style="display: grid; gap: 15px;">
              <div class="list-item">
                <div>
                  <i class="fas fa-plus-circle" style="color: var(--success);"></i>
                  <span style="margin-left: 10px;">Venda criada</span>
                </div>
                <span style="color: var(--text-secondary);"><%= formatDate(venda.createdAt) %></span>
              </div>
              <% if (venda.updatedAt && venda.updatedAt !== venda.createdAt) { %>
              <div class="list-item">
                <div>
                  <i class="fas fa-edit" style="color: var(--info);"></i>
                  <span style="margin-left: 10px;">Última atualização</span>
                </div>
                <span style="color: var(--text-secondary);"><%= formatDate(venda.updatedAt) %></span>
              </div>
              <% } %>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
