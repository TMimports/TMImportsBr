<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vendas Pendentes - Tecle Motos</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/topbar') %>
      <div class="content">
        <div class="page-header">
          <h1 class="page-title">Vendas Pendentes de Aprovação</h1>
        </div>

        <% if (vendas.length === 0) { %>
          <div class="card">
            <div class="card-body">
              <div class="empty-state">
                <i class="fas fa-check-circle"></i>
                <p>Nenhuma venda pendente de aprovação</p>
              </div>
            </div>
          </div>
        <% } else { %>
          <% vendas.forEach(venda => { %>
            <div class="card" style="margin-bottom: 20px;">
              <div class="card-header">
                <div>
                  <h3 class="card-title">Venda #<%= venda.id %> - <%= venda.cliente_nome %></h3>
                  <div style="font-size: 0.85rem; color: var(--text-secondary);">
                    Vendedor: <%= venda.vendedor ? venda.vendedor.nome : 'N/A' %> | 
                    Data: <%= formatDate(venda.data_venda) %>
                  </div>
                </div>
                <div style="text-align: right;">
                  <div style="font-size: 1.5rem; font-weight: bold; color: var(--orange);">
                    <%= formatCurrency(venda.valor_total) %>
                  </div>
                  <div style="font-size: 0.85rem; color: var(--text-secondary);">
                    <%= venda.forma_pagamento || 'N/A' %>
                  </div>
                </div>
              </div>
              <div class="card-body">
                <div class="form-row">
                  <div>
                    <h4 style="color: var(--green-neon); margin-bottom: 10px;">Cliente</h4>
                    <p><strong>Nome:</strong> <%= venda.cliente_nome %></p>
                    <p><strong>Telefone:</strong> <%= venda.cliente_telefone || 'N/A' %></p>
                    <p><strong>Email:</strong> <%= venda.cliente_email || 'N/A' %></p>
                  </div>
                  <div>
                    <h4 style="color: var(--green-neon); margin-bottom: 10px;">Estoque</h4>
                    <p><strong>Estoque:</strong> <%= venda.Estoque ? venda.Estoque.nome_estoque : 'N/A' %></p>
                    <p><strong>Subestoque:</strong> <%= venda.Subestoque ? venda.Subestoque.nome_subestoque : 'N/A' %></p>
                  </div>
                </div>
                
                <h4 style="color: var(--green-neon); margin: 20px 0 10px;">Itens</h4>
                <table style="margin-bottom: 20px;">
                  <thead>
                    <tr>
                      <th>Produto</th>
                      <th>Tipo</th>
                      <th>Modelo/Cor</th>
                      <th>Qtd</th>
                      <th>Preço Unit.</th>
                      <th>Subtotal</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (venda.ItemVendas) { venda.ItemVendas.forEach(item => { %>
                      <tr>
                        <td><%= item.Produto ? (item.Produto.nome_modelo || item.Produto.nome_produto) : 'N/A' %></td>
                        <td><%= item.Produto ? item.Produto.tipo : 'N/A' %></td>
                        <td><%= item.Produto ? (item.Produto.cor || '-') : '-' %></td>
                        <td><%= item.quantidade %></td>
                        <td><%= formatCurrency(item.preco_unitario) %></td>
                        <td><%= formatCurrency(item.quantidade * item.preco_unitario) %></td>
                      </tr>
                    <% }); } %>
                  </tbody>
                </table>
                
                <% 
                  const temMotoScooter = venda.ItemVendas && venda.ItemVendas.some(i => i.Produto && (i.Produto.tipo === 'MOTO' || i.Produto.tipo === 'SCOOTER'));
                %>
                
                <% if (temMotoScooter) { %>
                  <h4 style="color: var(--green-neon); margin: 20px 0 10px;">Selecionar Chassi</h4>
                  <div class="form-group">
                    <label class="form-label">Chassis Disponíveis (selecione para cada unidade de moto/scooter)</label>
                    <div id="chassiSelect-<%= venda.id %>">
                      <p style="color: var(--text-secondary); font-size: 0.9rem;">
                        Clique em "Carregar Chassis" para ver os chassis liberados
                      </p>
                      <button type="button" class="btn btn-secondary btn-sm" onclick="loadChassis(<%= venda.id %>)">
                        <i class="fas fa-barcode"></i> Carregar Chassis
                      </button>
                    </div>
                  </div>
                <% } %>
                
                <div style="display: flex; gap: 10px; margin-top: 20px;">
                  <form action="/vendas/<%= venda.id %>/concluir" method="POST" style="display: inline;">
                    <input type="hidden" name="chassis_selecionados" id="chassiInput-<%= venda.id %>" value="[]">
                    <button type="submit" class="btn btn-success">
                      <i class="fas fa-check"></i> Concluir Venda
                    </button>
                  </form>
                  <form action="/vendas/<%= venda.id %>/cancelar" method="POST" style="display: inline;" onsubmit="return confirm('Cancelar esta venda?')">
                    <button type="submit" class="btn btn-danger">
                      <i class="fas fa-times"></i> Cancelar Venda
                    </button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
  <script>
    function loadChassis(vendaId) {
      fetch('/chassi/api/disponiveis')
        .then(r => r.json())
        .then(chassis => {
          const container = document.getElementById('chassiSelect-' + vendaId);
          if (chassis.length === 0) {
            container.innerHTML = '<p style="color: var(--warning);">Nenhum chassi liberado disponível</p>';
            return;
          }
          let html = '<div style="max-height: 200px; overflow-y: auto;">';
          chassis.forEach(ch => {
            html += `
              <label class="checkbox-group" style="display: block; padding: 8px; border: 1px solid var(--border-color); border-radius: 6px; margin-bottom: 8px;">
                <input type="checkbox" class="chassi-check-${vendaId}" value="${ch.id}">
                <span><strong>${ch.numero_chassi}</strong> - ${ch.modelo} (${ch.cor})</span>
              </label>
            `;
          });
          html += '</div>';
          container.innerHTML = html;
          
          document.querySelectorAll('.chassi-check-' + vendaId).forEach(cb => {
            cb.addEventListener('change', () => updateChassiInput(vendaId));
          });
        });
    }
    
    function updateChassiInput(vendaId) {
      const selected = [];
      document.querySelectorAll('.chassi-check-' + vendaId + ':checked').forEach(cb => {
        selected.push(parseInt(cb.value));
      });
      document.getElementById('chassiInput-' + vendaId).value = JSON.stringify(selected);
    }
  </script>
</body>
</html>
