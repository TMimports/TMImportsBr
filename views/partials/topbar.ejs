<header class="topbar">
  <h2 class="topbar-title">
    <i class="fas fa-bolt" style="color: var(--green-neon);"></i>
    Sistema de Gestão
  </h2>
  <div class="topbar-user">
    <% if (user) { %>
      <div class="user-info">
        <div class="user-name"><%= user.nome %></div>
        <div class="user-role"><%= user.perfil.replace('_', ' ') %></div>
      </div>
      <a href="/logout" class="btn-logout">
        <i class="fas fa-sign-out-alt"></i> Sair
      </a>
    <% } %>
  </div>
</header>
