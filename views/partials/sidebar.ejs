<aside class="sidebar">
  <div class="sidebar-header">
    <img src="/images/logo.png" alt="Tecle Motos" class="sidebar-logo">
  </div>
  <nav class="sidebar-nav">
    <% if (user && user.perfil === 'SUPER_ADMIN') { %>
      <div class="nav-section">Principal</div>
      <a href="/dashboard" class="nav-item">
        <i class="fas fa-chart-line"></i>
        Dashboard
      </a>
    <% } %>
    
    <% if (user && user.perfil === 'VENDEDOR') { %>
      <div class="nav-section">Vendedor</div>
      <a href="/vendedor/dashboard" class="nav-item">
        <i class="fas fa-chart-bar"></i>
        Meu Dashboard
      </a>
      <a href="/vendedor/estoque" class="nav-item">
        <i class="fas fa-search"></i>
        Consultar Estoque
      </a>
    <% } %>
    
    <% if (user && (user.perfil === 'SUPER_ADMIN' || user.perfil === 'ADMIN')) { %>
      <div class="nav-section">Cadastros</div>
      <a href="/produtos" class="nav-item">
        <i class="fas fa-motorcycle"></i>
        Produtos / Serviços
      </a>
      <a href="/estoque" class="nav-item">
        <i class="fas fa-warehouse"></i>
        Estoque
      </a>
    <% } %>
    
    <% if (user && user.perfil === 'SUPER_ADMIN') { %>
      <a href="/chassi" class="nav-item">
        <i class="fas fa-barcode"></i>
        Chassi
      </a>
    <% } %>
    
    <% if (user && (user.perfil === 'SUPER_ADMIN' || user.perfil === 'ADMIN' || user.perfil === 'VENDEDOR')) { %>
      <div class="nav-section">Comercial</div>
      <a href="/vendas" class="nav-item">
        <i class="fas fa-shopping-cart"></i>
        Vendas
      </a>
    <% } %>
    
    <% if (user && user.perfil === 'SUPER_ADMIN') { %>
      <a href="/vendas/pendentes" class="nav-item">
        <i class="fas fa-clock"></i>
        Vendas Pendentes
      </a>
    <% } %>
    
    <% if (user && (user.perfil === 'SUPER_ADMIN' || user.perfil === 'CONTADOR')) { %>
      <div class="nav-section">Financeiro</div>
      <a href="/financeiro/contas-receber" class="nav-item">
        <i class="fas fa-hand-holding-usd"></i>
        Contas a Receber
      </a>
      <a href="/financeiro/contas-pagar" class="nav-item">
        <i class="fas fa-file-invoice-dollar"></i>
        Contas a Pagar
      </a>
      <a href="/financeiro/conciliacao" class="nav-item">
        <i class="fas fa-balance-scale"></i>
        Conciliação Bancária
      </a>
    <% } %>
    
    <% if (user && user.perfil === 'SUPER_ADMIN') { %>
      <div class="nav-section">Sistema</div>
      <a href="/usuarios" class="nav-item">
        <i class="fas fa-users-cog"></i>
        Usuários
      </a>
    <% } %>
  </nav>
</aside>
