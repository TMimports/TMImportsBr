<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Estoque - Tecle Motos</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/topbar') %>
      <div class="content">
        <div class="page-header">
          <h1 class="page-title">Gestão de Estoque</h1>
          <div class="actions">
            <button class="btn btn-primary" onclick="openModal('estoqueModal')">
              <i class="fas fa-warehouse"></i> Novo Estoque
            </button>
            <button class="btn btn-secondary" onclick="openModal('subestoqueModal')">
              <i class="fas fa-boxes"></i> Novo Subestoque
            </button>
            <button class="btn btn-success" onclick="openModal('itemModal')">
              <i class="fas fa-plus"></i> Adicionar Item
            </button>
            <% if (user.perfil === 'SUPER_ADMIN') { %>
              <button class="btn btn-danger" onclick="confirmarLimpeza('estoque')">
                <i class="fas fa-trash-alt"></i> Limpar Tudo
              </button>
            <% } %>
          </div>
        </div>

        <form class="search-bar" method="GET">
          <input type="text" name="search" class="form-control" placeholder="Pesquisar produto..." value="<%= search || '' %>">
          <button type="submit" class="btn btn-secondary"><i class="fas fa-search"></i></button>
        </form>

        <div class="charts-grid">
          <div class="card">
            <div class="card-header">
              <h3 class="card-title"><i class="fas fa-warehouse"></i> Estoques</h3>
            </div>
            <div class="card-body">
              <% if (estoques.length === 0) { %>
                <div class="empty-state">
                  <i class="fas fa-warehouse"></i>
                  <p>Nenhum estoque cadastrado</p>
                </div>
              <% } else { %>
                <% estoques.forEach(estoque => { %>
                  <div class="list-item">
                    <div>
                      <strong><%= estoque.nome_estoque %></strong>
                      <div style="font-size: 0.8rem; color: var(--text-secondary);">
                        <%= estoque.Subestoques ? estoque.Subestoques.length : 0 %> subestoque(s)
                      </div>
                    </div>
                    <div class="actions">
                      <button class="btn btn-sm btn-secondary" onclick='openEditEstoqueModal(<%= JSON.stringify(estoque) %>)'>
                        <i class="fas fa-edit"></i>
                      </button>
                      <form action="/estoque/estoques/<%= estoque.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Confirma exclusão?')">
                        <%- include('../partials/csrf') %>
                        <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                      </form>
                    </div>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>
          
          <div class="card">
            <div class="card-header">
              <h3 class="card-title"><i class="fas fa-boxes"></i> Subestoques</h3>
            </div>
            <div class="card-body">
              <% 
                let allSubs = [];
                estoques.forEach(e => { if (e.Subestoques) allSubs = allSubs.concat(e.Subestoques); });
              %>
              <% if (allSubs.length === 0) { %>
                <div class="empty-state">
                  <i class="fas fa-boxes"></i>
                  <p>Nenhum subestoque cadastrado</p>
                </div>
              <% } else { %>
                <% allSubs.forEach(sub => { %>
                  <div class="list-item">
                    <div>
                      <strong><%= sub.nome_subestoque %></strong>
                    </div>
                    <div class="actions">
                      <form action="/estoque/subestoques/<%= sub.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Confirma exclusão?')">
                        <%- include('../partials/csrf') %>
                        <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                      </form>
                    </div>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-cubes"></i> Itens em Estoque</h3>
          </div>
          <div class="card-body">
            <div class="table-container">
              <table>
                <thead>
                  <tr>
                    <th>Produto</th>
                    <th>Estoque</th>
                    <th>Subestoque</th>
                    <th>Quantidade</th>
                    <th>Mín.</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (itensEstoque.length === 0) { %>
                    <tr><td colspan="7" class="empty-state">Nenhum item em estoque</td></tr>
                  <% } else { %>
                    <% itensEstoque.forEach(item => { %>
                      <tr class="<%= item.quantidade <= item.quantidade_minima ? 'critical-stock' : '' %>">
                        <td><%= item.Produto ? (item.Produto.nome_modelo || item.Produto.nome_produto) : '-' %></td>
                        <td><%= item.Estoque ? item.Estoque.nome_estoque : '-' %></td>
                        <td><%= item.Subestoque ? item.Subestoque.nome_subestoque : '-' %></td>
                        <td><strong><%= item.quantidade %></strong></td>
                        <td><%= item.quantidade_minima %></td>
                        <td>
                          <span class="badge <%= item.quantidade <= item.quantidade_minima ? 'badge-danger' : 'badge-success' %>">
                            <%= item.quantidade <= item.quantidade_minima ? 'CRÍTICO' : 'OK' %>
                          </span>
                        </td>
                        <td>
                          <div class="actions">
                            <button class="btn btn-sm btn-secondary" onclick='openEditItemModal(<%= JSON.stringify(item) %>)'>
                              <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-warning" onclick='openBaixaModal(<%= item.id %>)'>
                              <i class="fas fa-minus"></i> Baixa
                            </button>
                            <form action="/estoque/itens/<%= item.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Confirma exclusão?')">
                              <%- include('../partials/csrf') %>
                              <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                            </form>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="estoqueModal">
    <div class="modal">
      <div class="modal-header">
        <h3 class="modal-title">Novo Estoque</h3>
        <button class="modal-close" onclick="closeModal('estoqueModal')">&times;</button>
      </div>
      <form action="/estoque/estoques" method="POST">
        <%- include('../partials/csrf') %>
        <div class="modal-body">
          <div class="form-group">
            <label class="form-label">Nome do Estoque *</label>
            <input type="text" name="nome_estoque" class="form-control" placeholder="Ex: Showroom, Depósito" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeModal('estoqueModal')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="subestoqueModal">
    <div class="modal">
      <div class="modal-header">
        <h3 class="modal-title">Novo Subestoque</h3>
        <button class="modal-close" onclick="closeModal('subestoqueModal')">&times;</button>
      </div>
      <form action="/estoque/subestoques" method="POST">
        <%- include('../partials/csrf') %>
        <div class="modal-body">
          <div class="form-group">
            <label class="form-label">Estoque *</label>
            <select name="estoque_id" class="form-control" required>
              <option value="">Selecione...</option>
              <% estoques.forEach(est => { %>
                <option value="<%= est.id %>"><%= est.nome_estoque %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Nome do Subestoque *</label>
            <input type="text" name="nome_subestoque" class="form-control" placeholder="Ex: Subestoque A" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeModal('subestoqueModal')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="itemModal">
    <div class="modal">
      <div class="modal-header">
        <h3 class="modal-title">Adicionar Item ao Estoque</h3>
        <button class="modal-close" onclick="closeModal('itemModal')">&times;</button>
      </div>
      <form action="/estoque/itens" method="POST">
        <%- include('../partials/csrf') %>
        <div class="modal-body">
          <div class="form-group">
            <label class="form-label">Produto *</label>
            <select name="produto_id" class="form-control" required>
              <option value="">Selecione...</option>
              <% produtos.forEach(prod => { %>
                <option value="<%= prod.id %>"><%= prod.nome_modelo || prod.nome_produto %> (<%= prod.tipo %>)</option>
              <% }) %>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Estoque *</label>
              <select name="estoque_id" class="form-control" required>
                <option value="">Selecione...</option>
                <% estoques.forEach(est => { %>
                  <option value="<%= est.id %>"><%= est.nome_estoque %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Subestoque</label>
              <select name="subestoque_id" class="form-control">
                <option value="">Nenhum</option>
                <% estoques.forEach(est => { 
                  if (est.Subestoques) {
                    est.Subestoques.forEach(sub => { %>
                      <option value="<%= sub.id %>"><%= sub.nome_subestoque %></option>
                <% }); } }) %>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Quantidade *</label>
              <input type="number" name="quantidade" class="form-control" min="0" required>
            </div>
            <div class="form-group">
              <label class="form-label">Quantidade Mínima</label>
              <input type="number" name="quantidade_minima" class="form-control" min="0" value="0">
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeModal('itemModal')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="editItemModal">
    <div class="modal">
      <div class="modal-header">
        <h3 class="modal-title">Editar Quantidade</h3>
        <button class="modal-close" onclick="closeModal('editItemModal')">&times;</button>
      </div>
      <form id="editItemForm" method="POST">
        <%- include('../partials/csrf') %>
        <div class="modal-body">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Quantidade</label>
              <input type="number" name="quantidade" id="edit_item_quantidade" class="form-control" min="0" required>
            </div>
            <div class="form-group">
              <label class="form-label">Quantidade Mínima</label>
              <input type="number" name="quantidade_minima" id="edit_item_minimo" class="form-control" min="0">
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeModal('editItemModal')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="baixaModal">
    <div class="modal">
      <div class="modal-header">
        <h3 class="modal-title">Dar Baixa no Estoque</h3>
        <button class="modal-close" onclick="closeModal('baixaModal')">&times;</button>
      </div>
      <form id="baixaForm" method="POST">
        <%- include('../partials/csrf') %>
        <div class="modal-body">
          <div class="form-group">
            <label class="form-label">Quantidade a dar baixa *</label>
            <input type="number" name="quantidade_baixa" class="form-control" min="1" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeModal('baixaModal')">Cancelar</button>
          <button type="submit" class="btn btn-warning">Dar Baixa</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/app.js"></script>
  <script>
    function openEditEstoqueModal(estoque) {
      alert('Funcionalidade de edição. Nome atual: ' + estoque.nome_estoque);
    }
    
    function openEditItemModal(item) {
      document.getElementById('editItemForm').action = '/estoque/itens/' + item.id + '/update';
      document.getElementById('edit_item_quantidade').value = item.quantidade;
      document.getElementById('edit_item_minimo').value = item.quantidade_minima;
      openModal('editItemModal');
    }
    
    function openBaixaModal(itemId) {
      document.getElementById('baixaForm').action = '/estoque/itens/' + itemId + '/baixa';
      openModal('baixaModal');
    }
    
    function confirmarLimpeza(tipo) {
      if (confirm('ATENÇÃO! Esta ação irá EXCLUIR PERMANENTEMENTE todos os estoques, subestoques e itens.\n\nDeseja continuar?')) {
        if (confirm('Tem CERTEZA ABSOLUTA? Esta ação não pode ser desfeita!')) {
          document.getElementById('formLimparEstoque').submit();
        }
      }
    }
  </script>
  
  <form id="formLimparEstoque" action="/estoque/limpar-tudo" method="POST" style="display:none;">
    <%- include('../partials/csrf') %>
  </form>
</body>
</html>
