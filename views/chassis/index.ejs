<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chassi - Tecle Motos</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/topbar') %>
      <div class="content">
        <div class="page-header">
          <h1 class="page-title">Gestão de Chassi</h1>
          <button class="btn btn-primary" onclick="openModal('createModal')">
            <i class="fas fa-plus"></i> Novo Chassi
          </button>
        </div>

        <form class="search-bar" method="GET">
          <input type="text" name="search" class="form-control" placeholder="Pesquisar número, modelo..." value="<%= filters.search || '' %>">
          <select name="status" class="form-control">
            <option value="">Todos Status</option>
            <option value="CADASTRADO" <%= filters.status === 'CADASTRADO' ? 'selected' : '' %>>Cadastrado</option>
            <option value="LIBERADO" <%= filters.status === 'LIBERADO' ? 'selected' : '' %>>Liberado</option>
            <option value="VENDIDO" <%= filters.status === 'VENDIDO' ? 'selected' : '' %>>Vendido</option>
            <option value="INATIVO" <%= filters.status === 'INATIVO' ? 'selected' : '' %>>Inativo</option>
          </select>
          <select name="modelo" class="form-control">
            <option value="">Todos Modelos</option>
            <% modelos.forEach(mod => { %>
              <option value="<%= mod %>" <%= filters.modelo === mod ? 'selected' : '' %>><%= mod %></option>
            <% }) %>
          </select>
          <button type="submit" class="btn btn-secondary"><i class="fas fa-search"></i></button>
        </form>

        <div class="card">
          <div class="card-body">
            <div class="table-container">
              <table>
                <thead>
                  <tr>
                    <th>Número do Chassi</th>
                    <th>Modelo</th>
                    <th>Cor</th>
                    <th>Estoque</th>
                    <th>Subestoque</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (chassis.length === 0) { %>
                    <tr><td colspan="7" class="empty-state">Nenhum chassi cadastrado</td></tr>
                  <% } else { %>
                    <% chassis.forEach(ch => { %>
                      <tr>
                        <td><strong><%= ch.numero_chassi %></strong></td>
                        <td><%= ch.modelo %></td>
                        <td><%= ch.cor %></td>
                        <td><%= ch.Estoque ? ch.Estoque.nome_estoque : '-' %></td>
                        <td><%= ch.Subestoque ? ch.Subestoque.nome_subestoque : '-' %></td>
                        <td>
                          <span class="badge badge-<%= ch.status === 'LIBERADO' ? 'success' : (ch.status === 'VENDIDO' ? 'info' : (ch.status === 'INATIVO' ? 'danger' : 'warning')) %>">
                            <%= ch.status %>
                          </span>
                        </td>
                        <td>
                          <div class="actions">
                            <button class="btn btn-sm btn-secondary" onclick='openEditModal(<%= JSON.stringify(ch) %>)'>
                              <i class="fas fa-edit"></i>
                            </button>
                            <% if (ch.status === 'CADASTRADO') { %>
                              <form action="/chassi/<%= ch.id %>/liberar" method="POST" style="display:inline;">
                                <%- include('../partials/csrf') %>
                                <button type="submit" class="btn btn-sm btn-success" title="Liberar">
                                  <i class="fas fa-check"></i>
                                </button>
                              </form>
                            <% } %>
                            <% if (ch.status !== 'VENDIDO') { %>
                              <form action="/chassi/<%= ch.id %>/inativar" method="POST" style="display:inline;">
                                <%- include('../partials/csrf') %>
                                <button type="submit" class="btn btn-sm btn-warning" title="Inativar">
                                  <i class="fas fa-ban"></i>
                                </button>
                              </form>
                            <% } %>
                            <form action="/chassi/<%= ch.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Confirma exclusão?')">
                              <%- include('../partials/csrf') %>
                              <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                            </form>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="createModal">
    <div class="modal">
      <div class="modal-header">
        <h3 class="modal-title">Novo Chassi</h3>
        <button class="modal-close" onclick="closeModal('createModal')">&times;</button>
      </div>
      <form action="/chassi" method="POST">
        <%- include('../partials/csrf') %>
        <div class="modal-body">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Modelo *</label>
              <input type="text" name="modelo" class="form-control" placeholder="Ex: TM13, TM Monaco" required>
            </div>
            <div class="form-group">
              <label class="form-label">Cor *</label>
              <input type="text" name="cor" class="form-control" placeholder="Ex: Vermelho, Preto" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Número do Chassi *</label>
            <input type="text" name="numero_chassi" class="form-control" placeholder="Número único do chassi" required>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Estoque</label>
              <select name="estoque_id" class="form-control">
                <option value="">Selecione...</option>
                <% estoques.forEach(est => { %>
                  <option value="<%= est.id %>"><%= est.nome_estoque %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Subestoque</label>
              <select name="subestoque_id" class="form-control">
                <option value="">Nenhum</option>
                <% subestoques.forEach(sub => { %>
                  <option value="<%= sub.id %>"><%= sub.nome_subestoque %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Status Inicial</label>
            <select name="status" class="form-control">
              <option value="CADASTRADO">Cadastrado</option>
              <option value="LIBERADO">Liberado para Venda</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeModal('createModal')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="editModal">
    <div class="modal">
      <div class="modal-header">
        <h3 class="modal-title">Editar Chassi</h3>
        <button class="modal-close" onclick="closeModal('editModal')">&times;</button>
      </div>
      <form id="editForm" method="POST">
        <%- include('../partials/csrf') %>
        <div class="modal-body">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Modelo</label>
              <input type="text" name="modelo" id="edit_modelo" class="form-control" required>
            </div>
            <div class="form-group">
              <label class="form-label">Cor</label>
              <input type="text" name="cor" id="edit_cor" class="form-control" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Número do Chassi</label>
            <input type="text" name="numero_chassi" id="edit_numero" class="form-control" required>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Estoque</label>
              <select name="estoque_id" id="edit_estoque" class="form-control">
                <option value="">Selecione...</option>
                <% estoques.forEach(est => { %>
                  <option value="<%= est.id %>"><%= est.nome_estoque %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Subestoque</label>
              <select name="subestoque_id" id="edit_subestoque" class="form-control">
                <option value="">Nenhum</option>
                <% subestoques.forEach(sub => { %>
                  <option value="<%= sub.id %>"><%= sub.nome_subestoque %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Status</label>
            <select name="status" id="edit_status" class="form-control">
              <option value="CADASTRADO">Cadastrado</option>
              <option value="LIBERADO">Liberado</option>
              <option value="VENDIDO">Vendido</option>
              <option value="INATIVO">Inativo</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeModal('editModal')">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/app.js"></script>
  <script>
    function openEditModal(chassi) {
      document.getElementById('editForm').action = '/chassi/' + chassi.id + '/update';
      document.getElementById('edit_modelo').value = chassi.modelo || '';
      document.getElementById('edit_cor').value = chassi.cor || '';
      document.getElementById('edit_numero').value = chassi.numero_chassi || '';
      document.getElementById('edit_estoque').value = chassi.estoque_id || '';
      document.getElementById('edit_subestoque').value = chassi.subestoque_id || '';
      document.getElementById('edit_status').value = chassi.status || 'CADASTRADO';
      openModal('editModal');
    }
  </script>
</body>
</html>
