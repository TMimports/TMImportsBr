<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Orçamentos - Tecle Motos</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/topbar') %>
      <div class="content">
        <div class="page-header">
          <h1 class="page-title"><i class="fas fa-file-invoice-dollar"></i> Orçamentos</h1>
          <a href="/orcamentos/novo" class="btn btn-primary">
            <i class="fas fa-plus"></i> Novo Orçamento
          </a>
        </div>

        <div class="card">
          <div class="card-header">
            <form method="GET" class="search-bar" style="flex-wrap: wrap; gap: 10px;">
              <input type="text" name="search" placeholder="Buscar por código ou cliente..." 
                     value="<%= filters.search || '' %>" class="form-control" style="min-width: 200px;">
              <select name="status" class="form-control" style="min-width: 140px;">
                <option value="">Todos os Status</option>
                <option value="RASCUNHO" <%= filters.status === 'RASCUNHO' ? 'selected' : '' %>>Rascunho</option>
                <option value="ENVIADO" <%= filters.status === 'ENVIADO' ? 'selected' : '' %>>Enviado</option>
                <option value="APROVADO" <%= filters.status === 'APROVADO' ? 'selected' : '' %>>Aprovado</option>
                <option value="EXPIRADO" <%= filters.status === 'EXPIRADO' ? 'selected' : '' %>>Expirado</option>
                <option value="CANCELADO" <%= filters.status === 'CANCELADO' ? 'selected' : '' %>>Cancelado</option>
              </select>
              <select name="origem_tipo" class="form-control" style="min-width: 140px;">
                <option value="">Todas as Origens</option>
                <option value="VENDA" <%= filters.origem_tipo === 'VENDA' ? 'selected' : '' %>>Venda</option>
                <option value="ORDEM_SERVICO" <%= filters.origem_tipo === 'ORDEM_SERVICO' ? 'selected' : '' %>>Ordem de Serviço</option>
              </select>
              <div style="display: flex; align-items: center; gap: 5px;">
                <label style="color: var(--text-secondary); font-size: 0.85rem;">De:</label>
                <input type="date" name="data_inicio" value="<%= filters.data_inicio || '' %>" class="form-control" style="min-width: 140px;">
              </div>
              <div style="display: flex; align-items: center; gap: 5px;">
                <label style="color: var(--text-secondary); font-size: 0.85rem;">Até:</label>
                <input type="date" name="data_fim" value="<%= filters.data_fim || '' %>" class="form-control" style="min-width: 140px;">
              </div>
              <button type="submit" class="btn btn-secondary"><i class="fas fa-search"></i></button>
              <a href="/orcamentos" class="btn btn-outline"><i class="fas fa-times"></i></a>
            </form>
          </div>
          
          <div class="table-container">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Código</th>
                  <th>Origem</th>
                  <th>Cliente</th>
                  <th>Emissão</th>
                  <th>Validade</th>
                  <th>Total</th>
                  <th>Status</th>
                  <th>Ações</th>
                </tr>
              </thead>
              <tbody>
                <% if (orcamentos.length === 0) { %>
                  <tr>
                    <td colspan="8" class="text-center">Nenhum orçamento encontrado</td>
                  </tr>
                <% } %>
                <% orcamentos.forEach(orc => { %>
                  <tr>
                    <td><strong><%= orc.codigo %></strong></td>
                    <td>
                      <% if (orc.origem_tipo === 'VENDA') { %>
                        <span class="status-badge status-info">Venda</span>
                      <% } else { %>
                        <span class="status-badge status-warning">OS</span>
                      <% } %>
                    </td>
                    <td><%= orc.cliente_nome %></td>
                    <td><%= new Date(orc.data_emissao).toLocaleDateString('pt-BR') %></td>
                    <td>
                      <% 
                        const now = new Date();
                        const validade = new Date(orc.data_validade);
                        const isExpired = validade < now && orc.status !== 'APROVADO' && orc.status !== 'CANCELADO';
                      %>
                      <span class="<%= isExpired ? 'text-danger' : '' %>">
                        <%= validade.toLocaleDateString('pt-BR') %>
                      </span>
                    </td>
                    <td>R$ <%= parseFloat(orc.total || 0).toFixed(2).replace('.', ',') %></td>
                    <td>
                      <% 
                        let statusClass = '';
                        let statusText = orc.status;
                        switch(orc.status) {
                          case 'RASCUNHO': statusClass = 'status-pending'; statusText = 'Rascunho'; break;
                          case 'ENVIADO': statusClass = 'status-progress'; statusText = 'Enviado'; break;
                          case 'APROVADO': statusClass = 'status-completed'; statusText = 'Aprovado'; break;
                          case 'EXPIRADO': statusClass = 'status-cancelled'; statusText = 'Expirado'; break;
                          case 'CANCELADO': statusClass = 'status-cancelled'; statusText = 'Cancelado'; break;
                        }
                      %>
                      <span class="status-badge <%= statusClass %>"><%= statusText %></span>
                    </td>
                    <td>
                      <div class="actions">
                        <a href="/orcamentos/<%= orc.id %>" class="btn btn-sm btn-info" title="Ver">
                          <i class="fas fa-eye"></i>
                        </a>
                        <a href="/orcamentos/<%= orc.id %>/imprimir" class="btn btn-sm btn-secondary" title="Imprimir" target="_blank">
                          <i class="fas fa-print"></i>
                        </a>
                        <% if (user.perfil === 'SUPER_ADMIN') { %>
                          <form action="/orcamentos/<%= orc.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Excluir orçamento?')">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn btn-sm btn-danger" title="Excluir">
                              <i class="fas fa-trash"></i>
                            </button>
                          </form>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
