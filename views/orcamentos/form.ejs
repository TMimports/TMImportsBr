<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Novo Orçamento - Tecle Motos</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/topbar') %>
      <div class="content">
        <div class="page-header">
          <h1 class="page-title"><i class="fas fa-file-invoice-dollar"></i> Novo Orçamento</h1>
          <a href="/orcamentos" class="btn btn-outline">
            <i class="fas fa-arrow-left"></i> Voltar
          </a>
        </div>

        <form method="POST" action="/orcamentos/novo" id="orcamentoForm">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          
          <div class="card">
            <div class="card-header">
              <h3><i class="fas fa-user"></i> Dados do Cliente</h3>
            </div>
            <div class="card-body">
              <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-group">
                  <label>Nome do Cliente *</label>
                  <input type="text" name="cliente_nome" class="form-control" required>
                </div>
                <div class="form-group">
                  <label>CPF/CNPJ</label>
                  <input type="text" name="cliente_cpf_cnpj" class="form-control">
                </div>
                <div class="form-group">
                  <label>Telefone</label>
                  <input type="text" name="cliente_telefone" class="form-control">
                </div>
                <div class="form-group">
                  <label>Email</label>
                  <input type="email" name="cliente_email" class="form-control">
                </div>
              </div>
              <div class="form-group">
                <label>Endereço</label>
                <textarea name="cliente_endereco" class="form-control" rows="2"></textarea>
              </div>
            </div>
          </div>
          
          <div class="card" style="margin-top: 20px;">
            <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
              <h3><i class="fas fa-list"></i> Itens do Orçamento</h3>
              <button type="button" class="btn btn-sm btn-primary" onclick="addItem()">
                <i class="fas fa-plus"></i> Adicionar Item
              </button>
            </div>
            <div class="card-body">
              <div class="table-container">
                <table class="data-table" id="itensTable">
                  <thead>
                    <tr>
                      <th>Tipo</th>
                      <th>Produto/Serviço</th>
                      <th>Descrição</th>
                      <th>Qtd</th>
                      <th>Preço Unit.</th>
                      <th>Desconto</th>
                      <th>Total</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody id="itensList">
                  </tbody>
                  <tfoot>
                    <tr>
                      <td colspan="5"></td>
                      <td><strong>Subtotal:</strong></td>
                      <td><strong id="subtotal">R$ 0,00</strong></td>
                      <td></td>
                    </tr>
                    <tr>
                      <td colspan="5"></td>
                      <td><strong>Desconto:</strong></td>
                      <td><strong id="descontoTotal">R$ 0,00</strong></td>
                      <td></td>
                    </tr>
                    <tr>
                      <td colspan="5"></td>
                      <td><strong>Total:</strong></td>
                      <td><strong id="total" class="text-success">R$ 0,00</strong></td>
                      <td></td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>
          </div>
          
          <div class="card" style="margin-top: 20px;">
            <div class="card-header">
              <h3><i class="fas fa-sticky-note"></i> Observações</h3>
            </div>
            <div class="card-body">
              <div class="form-group">
                <textarea name="observacoes" class="form-control" rows="3" placeholder="Observações adicionais, condições de pagamento, garantia, etc."></textarea>
              </div>
            </div>
          </div>
          
          <input type="hidden" name="itens" id="itensInput">
          
          <div class="form-actions" style="margin-top: 20px; display: flex; gap: 10px;">
            <button type="submit" class="btn btn-primary">
              <i class="fas fa-save"></i> Salvar Orçamento
            </button>
            <a href="/orcamentos" class="btn btn-outline">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
  const produtos = <%- JSON.stringify(produtos.map(p => ({
    id: p.id,
    nome: p.nome_modelo || p.nome_produto || 'Sem nome',
    preco_venda: p.preco_venda,
    tipo: p.tipo,
    chassi: p.chassi || ''
  }))) %>;
  let itens = [];
  
  function getFilteredProducts(tipoItem) {
    if (tipoItem === 'MOTO') {
      return produtos.filter(p => p.tipo === 'MOTO' || p.tipo === 'SCOOTER');
    } else if (tipoItem === 'PRODUTO') {
      return produtos.filter(p => p.tipo === 'PECA' || p.tipo === 'PRODUTO');
    } else if (tipoItem === 'SERVICO') {
      return produtos.filter(p => p.tipo === 'SERVICO');
    }
    return produtos;
  }
  
  function buildProductOptions(tipoItem, selectedId) {
    let filtered = getFilteredProducts(tipoItem);
    if (selectedId) {
      const selectedProduct = produtos.find(p => p.id == selectedId);
      if (selectedProduct && !filtered.find(p => p.id == selectedId)) {
        filtered = [selectedProduct, ...filtered];
      }
    }
    return '<option value="">-- Manual --</option>' + 
      filtered.map(p => {
        const chassiInfo = p.chassi ? ` - Chassi: ${p.chassi}` : '';
        return `<option value="${p.id}" ${p.id == selectedId ? 'selected' : ''}>${p.nome}${chassiInfo}</option>`;
      }).join('');
  }

  function renderItens() {
    const tbody = document.getElementById('itensList');
    tbody.innerHTML = '';
    
    let subtotal = 0;
    let descontoTotal = 0;
    
    itens.forEach((item, index) => {
      const itemTotal = (item.preco_unitario * item.quantidade) - item.desconto;
      subtotal += item.preco_unitario * item.quantidade;
      descontoTotal += item.desconto;
      
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>
          <select onchange="updateItemType(${index}, this.value)" class="form-control form-control-sm">
            <option value="MOTO" ${item.tipo_item === 'MOTO' ? 'selected' : ''}>Moto</option>
            <option value="PRODUTO" ${item.tipo_item === 'PRODUTO' ? 'selected' : ''}>Produto</option>
            <option value="SERVICO" ${item.tipo_item === 'SERVICO' ? 'selected' : ''}>Serviço</option>
            <option value="MAO_DE_OBRA" ${item.tipo_item === 'MAO_DE_OBRA' ? 'selected' : ''}>Mão de Obra</option>
          </select>
        </td>
        <td>
          <select onchange="selectProduto(${index}, this.value)" class="form-control form-control-sm" id="prodSelect_${index}">
            ${buildProductOptions(item.tipo_item, item.produto_id)}
          </select>
        </td>
        <td>
          <input type="text" value="${item.descricao}" onchange="updateItem(${index}, 'descricao', this.value)" 
                 class="form-control form-control-sm" placeholder="Descrição do item">
        </td>
        <td>
          <input type="number" value="${item.quantidade}" min="1" onchange="updateItem(${index}, 'quantidade', parseInt(this.value))" 
                 class="form-control form-control-sm" style="width: 60px">
        </td>
        <td>
          <input type="number" value="${item.preco_unitario.toFixed(2)}" step="0.01" onchange="updateItem(${index}, 'preco_unitario', parseFloat(this.value))" 
                 class="form-control form-control-sm" style="width: 100px">
        </td>
        <td>
          <input type="number" value="${item.desconto.toFixed(2)}" step="0.01" onchange="updateItem(${index}, 'desconto', parseFloat(this.value))" 
                 class="form-control form-control-sm" style="width: 80px">
        </td>
        <td>R$ ${itemTotal.toFixed(2).replace('.', ',')}</td>
        <td>
          <button type="button" onclick="removeItem(${index})" class="btn btn-sm btn-danger">
            <i class="fas fa-trash"></i>
          </button>
        </td>
      `;
      tbody.appendChild(tr);
    });
    
    document.getElementById('subtotal').textContent = 'R$ ' + subtotal.toFixed(2).replace('.', ',');
    document.getElementById('descontoTotal').textContent = 'R$ ' + descontoTotal.toFixed(2).replace('.', ',');
    document.getElementById('total').textContent = 'R$ ' + (subtotal - descontoTotal).toFixed(2).replace('.', ',');
    document.getElementById('itensInput').value = JSON.stringify(itens);
  }

  function addItem() {
    itens.push({
      produto_id: null,
      tipo_item: 'SERVICO',
      descricao: '',
      quantidade: 1,
      preco_unitario: 0,
      desconto: 0,
      total: 0
    });
    renderItens();
  }

  function updateItem(index, field, value) {
    itens[index][field] = value;
    itens[index].total = (itens[index].preco_unitario * itens[index].quantidade) - itens[index].desconto;
    renderItens();
  }
  
  function updateItemType(index, tipoItem) {
    itens[index].tipo_item = tipoItem;
    itens[index].produto_id = null;
    itens[index].descricao = '';
    itens[index].preco_unitario = 0;
    renderItens();
  }

  function selectProduto(index, produtoId) {
    if (produtoId) {
      const produto = produtos.find(p => p.id == produtoId);
      if (produto) {
        itens[index].produto_id = produto.id;
        itens[index].descricao = produto.nome + (produto.chassi ? ' - Chassi: ' + produto.chassi : '');
        itens[index].preco_unitario = parseFloat(produto.preco_venda);
        itens[index].total = (itens[index].preco_unitario * itens[index].quantidade) - itens[index].desconto;
      }
    } else {
      itens[index].produto_id = null;
    }
    renderItens();
  }

  function removeItem(index) {
    itens.splice(index, 1);
    renderItens();
  }

  document.getElementById('orcamentoForm').addEventListener('submit', function(e) {
    document.getElementById('itensInput').value = JSON.stringify(itens);
  });

  renderItens();
  </script>
  <script src="/js/app.js"></script>
</body>
</html>
