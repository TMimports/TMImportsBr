<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= ordemServico.codigo %> - Tecle Motos</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/topbar') %>
      <div class="content">
        <div class="page-header">
          <h1 class="page-title"><i class="fas fa-tools"></i> <%= ordemServico.codigo %></h1>
          <div style="display: flex; gap: 10px;">
            <% if (ordemServico.status !== 'CONCLUIDA' && ordemServico.status !== 'CANCELADA') { %>
              <a href="/ordens-servico/<%= ordemServico.id %>/editar" class="btn btn-warning">
                <i class="fas fa-edit"></i> Editar
              </a>
              <% if (ordemServico.itens && ordemServico.itens.length > 0) { %>
                <form method="POST" action="/ordens-servico/<%= ordemServico.id %>/gerar-orcamento" style="display: inline;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-primary">
                    <i class="fas fa-file-invoice-dollar"></i> Gerar Orçamento
                  </button>
                </form>
              <% } %>
            <% } %>
            <a href="/ordens-servico" class="btn btn-outline">
              <i class="fas fa-arrow-left"></i> Voltar
            </a>
          </div>
        </div>

        <div style="margin-bottom: 20px; display: flex; align-items: center; gap: 15px;">
          <% 
            let statusClass = '';
            let statusText = ordemServico.status;
            switch(ordemServico.status) {
              case 'ABERTA': statusClass = 'status-pending'; statusText = 'Aberta'; break;
              case 'EM_EXECUCAO': statusClass = 'status-progress'; statusText = 'Em Execução'; break;
              case 'AGUARDANDO_APROVACAO': statusClass = 'status-warning'; statusText = 'Aguardando Aprovação'; break;
              case 'APROVADA': statusClass = 'status-info'; statusText = 'Aprovada'; break;
              case 'CONCLUIDA': statusClass = 'status-completed'; statusText = 'Concluída'; break;
              case 'CANCELADA': statusClass = 'status-cancelled'; statusText = 'Cancelada'; break;
            }
          %>
          <span class="status-badge <%= statusClass %>" style="font-size: 1.1rem; padding: 8px 16px;"><%= statusText %></span>
          
          <% if (orcamento) { %>
            <a href="/orcamentos/<%= orcamento.id %>" class="btn btn-sm btn-info">
              <i class="fas fa-file-invoice-dollar"></i> Ver Orçamento (<%= orcamento.codigo %>)
            </a>
          <% } %>
        </div>

        <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
          <div class="card">
            <div class="card-header">
              <h3><i class="fas fa-user"></i> Dados do Cliente</h3>
            </div>
            <div class="card-body">
              <div class="info-row" style="margin-bottom: 10px;">
                <label style="color: var(--text-secondary); display: block;">Nome:</label>
                <span style="color: var(--text-primary);"><%= ordemServico.cliente_nome %></span>
              </div>
              <% if (ordemServico.cliente_cpf_cnpj) { %>
              <div class="info-row" style="margin-bottom: 10px;">
                <label style="color: var(--text-secondary); display: block;">CPF/CNPJ:</label>
                <span style="color: var(--text-primary);"><%= ordemServico.cliente_cpf_cnpj %></span>
              </div>
              <% } %>
              <% if (ordemServico.cliente_telefone) { %>
              <div class="info-row" style="margin-bottom: 10px;">
                <label style="color: var(--text-secondary); display: block;">Telefone:</label>
                <span style="color: var(--text-primary);"><%= ordemServico.cliente_telefone %></span>
              </div>
              <% } %>
              <% if (ordemServico.cliente_email) { %>
              <div class="info-row" style="margin-bottom: 10px;">
                <label style="color: var(--text-secondary); display: block;">Email:</label>
                <span style="color: var(--text-primary);"><%= ordemServico.cliente_email %></span>
              </div>
              <% } %>
              <% if (ordemServico.cliente_endereco) { %>
              <div class="info-row" style="margin-bottom: 10px;">
                <label style="color: var(--text-secondary); display: block;">Endereço:</label>
                <span style="color: var(--text-primary);"><%= ordemServico.cliente_endereco %></span>
              </div>
              <% } %>
            </div>
          </div>
          
          <div class="card">
            <div class="card-header">
              <h3><i class="fas fa-motorcycle"></i> Dados do Veículo</h3>
            </div>
            <div class="card-body">
              <% if (ordemServico.veiculo_modelo) { %>
              <div class="info-row" style="margin-bottom: 10px;">
                <label style="color: var(--text-secondary); display: block;">Modelo:</label>
                <span style="color: var(--text-primary);"><%= ordemServico.veiculo_modelo %></span>
              </div>
              <% } %>
              <% if (ordemServico.veiculo_placa) { %>
              <div class="info-row" style="margin-bottom: 10px;">
                <label style="color: var(--text-secondary); display: block;">Placa:</label>
                <span style="color: var(--text-primary);"><%= ordemServico.veiculo_placa %></span>
              </div>
              <% } %>
              <% if (ordemServico.veiculo_chassi) { %>
              <div class="info-row" style="margin-bottom: 10px;">
                <label style="color: var(--text-secondary); display: block;">Chassi:</label>
                <span style="color: var(--text-primary);"><%= ordemServico.veiculo_chassi %></span>
              </div>
              <% } %>
              <% if (ordemServico.veiculo_cor) { %>
              <div class="info-row" style="margin-bottom: 10px;">
                <label style="color: var(--text-secondary); display: block;">Cor:</label>
                <span style="color: var(--text-primary);"><%= ordemServico.veiculo_cor %></span>
              </div>
              <% } %>
              <% if (ordemServico.veiculo_km) { %>
              <div class="info-row" style="margin-bottom: 10px;">
                <label style="color: var(--text-secondary); display: block;">KM:</label>
                <span style="color: var(--text-primary);"><%= ordemServico.veiculo_km %></span>
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <div class="card" style="margin-top: 20px;">
          <div class="card-header">
            <h3><i class="fas fa-wrench"></i> Informações do Serviço</h3>
          </div>
          <div class="card-body">
            <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
              <div>
                <div class="info-row" style="margin-bottom: 10px;">
                  <label style="color: var(--text-secondary); display: block;">Descrição do Problema:</label>
                  <p style="color: var(--text-primary); margin: 5px 0;"><%= ordemServico.descricao_problema %></p>
                </div>
                <% if (ordemServico.diagnostico) { %>
                <div class="info-row" style="margin-bottom: 10px;">
                  <label style="color: var(--text-secondary); display: block;">Diagnóstico:</label>
                  <p style="color: var(--text-primary); margin: 5px 0;"><%= ordemServico.diagnostico %></p>
                </div>
                <% } %>
              </div>
              <div>
                <div class="info-row" style="margin-bottom: 10px;">
                  <label style="color: var(--text-secondary); display: block;">Entrada:</label>
                  <span style="color: var(--text-primary);"><%= new Date(ordemServico.data_entrada).toLocaleDateString('pt-BR') %></span>
                </div>
                <% if (ordemServico.data_prevista_entrega) { %>
                <div class="info-row" style="margin-bottom: 10px;">
                  <label style="color: var(--text-secondary); display: block;">Previsão de Entrega:</label>
                  <span style="color: var(--text-primary);"><%= new Date(ordemServico.data_prevista_entrega).toLocaleDateString('pt-BR') %></span>
                </div>
                <% } %>
                <div class="info-row" style="margin-bottom: 10px;">
                  <label style="color: var(--text-secondary); display: block;">Vendedor:</label>
                  <span style="color: var(--text-primary);"><%= ordemServico.vendedor ? ordemServico.vendedor.nome : '-' %></span>
                </div>
                <% if (ordemServico.responsavelTecnico) { %>
                <div class="info-row" style="margin-bottom: 10px;">
                  <label style="color: var(--text-secondary); display: block;">Técnico Responsável:</label>
                  <span style="color: var(--text-primary);"><%= ordemServico.responsavelTecnico.nome %></span>
                </div>
                <% } %>
              </div>
            </div>
            <% if (ordemServico.observacoes) { %>
            <div class="info-row" style="margin-top: 15px;">
              <label style="color: var(--text-secondary); display: block;">Observações:</label>
              <p style="color: var(--text-primary); margin: 5px 0;"><%= ordemServico.observacoes %></p>
            </div>
            <% } %>
          </div>
        </div>

        <div class="card" style="margin-top: 20px;">
          <div class="card-header">
            <h3><i class="fas fa-list"></i> Itens</h3>
          </div>
          <div class="card-body">
            <div class="table-container">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Tipo</th>
                    <th>Descrição</th>
                    <th>Qtd</th>
                    <th>Preço Unit.</th>
                    <th>Desconto</th>
                    <th>Total</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!ordemServico.itens || ordemServico.itens.length === 0) { %>
                    <tr>
                      <td colspan="6" class="text-center">Nenhum item adicionado</td>
                    </tr>
                  <% } else { %>
                    <% ordemServico.itens.forEach(item => { %>
                      <tr>
                        <td>
                          <% 
                            let tipoLabel = item.tipo_item;
                            if (item.tipo_item === 'PRODUTO') tipoLabel = 'Produto';
                            else if (item.tipo_item === 'SERVICO') tipoLabel = 'Serviço';
                            else if (item.tipo_item === 'MAO_DE_OBRA') tipoLabel = 'Mão de Obra';
                          %>
                          <%= tipoLabel %>
                        </td>
                        <td><%= item.descricao %></td>
                        <td><%= item.quantidade %></td>
                        <td>R$ <%= parseFloat(item.preco_unitario).toFixed(2).replace('.', ',') %></td>
                        <td>R$ <%= parseFloat(item.desconto || 0).toFixed(2).replace('.', ',') %></td>
                        <td>R$ <%= parseFloat(item.total).toFixed(2).replace('.', ',') %></td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
                <tfoot>
                  <tr>
                    <td colspan="4"></td>
                    <td><strong>Subtotal:</strong></td>
                    <td><strong>R$ <%= parseFloat(ordemServico.subtotal || 0).toFixed(2).replace('.', ',') %></strong></td>
                  </tr>
                  <tr>
                    <td colspan="4"></td>
                    <td><strong>Desconto:</strong></td>
                    <td><strong>R$ <%= parseFloat(ordemServico.desconto_total || 0).toFixed(2).replace('.', ',') %></strong></td>
                  </tr>
                  <tr>
                    <td colspan="4"></td>
                    <td><strong>Total:</strong></td>
                    <td><strong class="text-success">R$ <%= parseFloat(ordemServico.total || 0).toFixed(2).replace('.', ',') %></strong></td>
                  </tr>
                </tfoot>
              </table>
            </div>
          </div>
        </div>

        <% if (user.perfil === 'SUPER_ADMIN' && ordemServico.status !== 'CONCLUIDA' && ordemServico.status !== 'CANCELADA') { %>
        <div class="card" style="margin-top: 20px;">
          <div class="card-header">
            <h3><i class="fas fa-cogs"></i> Ações do Administrador</h3>
          </div>
          <div class="card-body">
            <form method="POST" action="/ordens-servico/<%= ordemServico.id %>/status" style="display: flex; gap: 10px; align-items: center;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <select name="status" class="form-control" style="width: auto;">
                <option value="ABERTA" <%= ordemServico.status === 'ABERTA' ? 'selected' : '' %>>Aberta</option>
                <option value="EM_EXECUCAO" <%= ordemServico.status === 'EM_EXECUCAO' ? 'selected' : '' %>>Em Execução</option>
                <option value="AGUARDANDO_APROVACAO" <%= ordemServico.status === 'AGUARDANDO_APROVACAO' ? 'selected' : '' %>>Aguardando Aprovação</option>
                <option value="APROVADA" <%= ordemServico.status === 'APROVADA' ? 'selected' : '' %>>Aprovada</option>
                <option value="CONCLUIDA">Concluída (baixa estoque)</option>
                <option value="CANCELADA">Cancelada</option>
              </select>
              <button type="submit" class="btn btn-primary">Atualizar Status</button>
            </form>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
