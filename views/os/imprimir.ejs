<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ordem de Serviço <%= ordemServico.codigo %> - Tecle Motos</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, sans-serif; font-size: 12px; color: #333; background: #fff; padding: 20px; }
    .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid #FF6B35; padding-bottom: 15px; margin-bottom: 20px; }
    .logo { display: flex; align-items: center; gap: 10px; }
    .logo-text { font-size: 24px; font-weight: bold; color: #FF6B35; }
    .logo-sub { font-size: 10px; color: #666; }
    .doc-info { text-align: right; }
    .doc-info h2 { font-size: 18px; color: #FF6B35; margin-bottom: 5px; }
    .doc-info p { margin: 3px 0; }
    .section { margin-bottom: 20px; }
    .section-title { background: #333; color: #fff; padding: 8px 15px; font-size: 14px; font-weight: bold; margin-bottom: 10px; }
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 0 15px; }
    .info-row { margin-bottom: 8px; }
    .info-row label { color: #666; font-size: 10px; display: block; }
    .info-row span { font-size: 12px; font-weight: 500; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 15px; }
    th { background: #f5f5f5; border: 1px solid #ddd; padding: 8px; text-align: left; font-size: 11px; }
    td { border: 1px solid #ddd; padding: 8px; font-size: 11px; }
    .text-right { text-align: right; }
    .totals { margin-top: 20px; }
    .totals table { width: 300px; margin-left: auto; }
    .totals td { border: none; padding: 5px 10px; }
    .totals .total-row { font-size: 14px; font-weight: bold; background: #FF6B35; color: #fff; }
    .signature-area { margin-top: 40px; display: flex; justify-content: space-between; }
    .signature-box { width: 45%; text-align: center; }
    .signature-line { border-top: 1px solid #333; margin-top: 50px; padding-top: 5px; font-size: 11px; }
    .status-badge { display: inline-block; padding: 4px 12px; border-radius: 4px; font-weight: bold; font-size: 11px; }
    .status-aberta { background: #ffc107; color: #000; }
    .status-execucao { background: #17a2b8; color: #fff; }
    .status-concluida { background: #28a745; color: #fff; }
    .status-cancelada { background: #dc3545; color: #fff; }
    .footer { margin-top: 30px; text-align: center; color: #666; font-size: 10px; border-top: 1px solid #ddd; padding-top: 15px; }
    .problem-box { background: #f9f9f9; padding: 10px 15px; border-left: 4px solid #FF6B35; margin: 10px 15px; }
    @media print {
      body { padding: 10px; }
      .no-print { display: none; }
    }
  </style>
</head>
<body>
  <div class="no-print" style="margin-bottom: 20px; text-align: right;">
    <button onclick="window.print()" style="background: #FF6B35; color: #fff; border: none; padding: 10px 20px; cursor: pointer; border-radius: 5px;">
      <i class="fas fa-print"></i> Imprimir
    </button>
    <button onclick="window.close()" style="background: #666; color: #fff; border: none; padding: 10px 20px; cursor: pointer; border-radius: 5px; margin-left: 10px;">
      Fechar
    </button>
  </div>

  <div class="header">
    <div class="logo">
      <div>
        <div class="logo-text">TECLE MOTOS</div>
        <div class="logo-sub">Motos e Scooters Elétricas</div>
      </div>
    </div>
    <div class="doc-info">
      <h2>ORDEM DE SERVIÇO</h2>
      <p><strong><%= ordemServico.codigo %></strong></p>
      <p>Data: <%= new Date(ordemServico.data_entrada).toLocaleDateString('pt-BR') %></p>
      <% 
        let statusClass = 'status-aberta';
        let statusText = ordemServico.status;
        if (ordemServico.status === 'EM_EXECUCAO') { statusClass = 'status-execucao'; statusText = 'Em Execução'; }
        else if (ordemServico.status === 'CONCLUIDA') { statusClass = 'status-concluida'; statusText = 'Concluída'; }
        else if (ordemServico.status === 'CANCELADA') { statusClass = 'status-cancelada'; statusText = 'Cancelada'; }
        else if (ordemServico.status === 'ABERTA') { statusText = 'Aberta'; }
        else if (ordemServico.status === 'APROVADA') { statusClass = 'status-execucao'; statusText = 'Aprovada'; }
      %>
      <span class="status-badge <%= statusClass %>"><%= statusText %></span>
    </div>
  </div>

  <div class="section">
    <div class="section-title">DADOS DO CLIENTE</div>
    <div class="info-grid">
      <div class="info-row">
        <label>Nome</label>
        <span><%= ordemServico.cliente_nome %></span>
      </div>
      <div class="info-row">
        <label>CPF/CNPJ</label>
        <span><%= ordemServico.cliente_cpf_cnpj || '-' %></span>
      </div>
      <div class="info-row">
        <label>Telefone</label>
        <span><%= ordemServico.cliente_telefone || '-' %></span>
      </div>
      <div class="info-row">
        <label>Email</label>
        <span><%= ordemServico.cliente_email || '-' %></span>
      </div>
    </div>
    <div style="padding: 0 15px;">
      <div class="info-row">
        <label>Endereço</label>
        <span><%= ordemServico.cliente_endereco || '-' %></span>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">DADOS DO VEÍCULO</div>
    <div class="info-grid">
      <div class="info-row">
        <label>Modelo</label>
        <span><%= ordemServico.veiculo_modelo || '-' %></span>
      </div>
      <div class="info-row">
        <label>Placa</label>
        <span><%= ordemServico.veiculo_placa || '-' %></span>
      </div>
      <div class="info-row">
        <label>Chassi</label>
        <span><%= ordemServico.veiculo_chassi || '-' %></span>
      </div>
      <div class="info-row">
        <label>Cor</label>
        <span><%= ordemServico.veiculo_cor || '-' %></span>
      </div>
      <div class="info-row">
        <label>KM</label>
        <span><%= ordemServico.veiculo_km || '-' %></span>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">DESCRIÇÃO DO PROBLEMA</div>
    <div class="problem-box">
      <%= ordemServico.descricao_problema %>
    </div>
    <% if (ordemServico.diagnostico) { %>
    <div class="section-title" style="margin-top: 15px;">DIAGNÓSTICO</div>
    <div class="problem-box">
      <%= ordemServico.diagnostico %>
    </div>
    <% } %>
  </div>

  <div class="section">
    <div class="section-title">ITENS / SERVIÇOS</div>
    <table>
      <thead>
        <tr>
          <th>Tipo</th>
          <th>Descrição</th>
          <th class="text-right">Qtd</th>
          <th class="text-right">Preço Unit.</th>
          <th class="text-right">Desconto</th>
          <th class="text-right">Total</th>
        </tr>
      </thead>
      <tbody>
        <% if (ordemServico.itens && ordemServico.itens.length > 0) { %>
          <% ordemServico.itens.forEach(item => { %>
            <tr>
              <td>
                <% if (item.tipo_item === 'PRODUTO') { %>Produto<% } 
                   else if (item.tipo_item === 'SERVICO') { %>Serviço<% } 
                   else { %>Mão de Obra<% } %>
              </td>
              <td><%= item.descricao %></td>
              <td class="text-right"><%= item.quantidade %></td>
              <td class="text-right">R$ <%= parseFloat(item.preco_unitario).toFixed(2).replace('.', ',') %></td>
              <td class="text-right">R$ <%= parseFloat(item.desconto || 0).toFixed(2).replace('.', ',') %></td>
              <td class="text-right">R$ <%= parseFloat(item.total).toFixed(2).replace('.', ',') %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6" style="text-align: center;">Nenhum item adicionado</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="totals">
    <table>
      <tr>
        <td>Subtotal:</td>
        <td class="text-right">R$ <%= parseFloat(ordemServico.subtotal || 0).toFixed(2).replace('.', ',') %></td>
      </tr>
      <tr>
        <td>Desconto:</td>
        <td class="text-right">R$ <%= parseFloat(ordemServico.desconto_total || 0).toFixed(2).replace('.', ',') %></td>
      </tr>
      <tr class="total-row">
        <td>TOTAL:</td>
        <td class="text-right">R$ <%= parseFloat(ordemServico.total || 0).toFixed(2).replace('.', ',') %></td>
      </tr>
    </table>
  </div>

  <% if (ordemServico.observacoes) { %>
  <div class="section" style="margin-top: 20px;">
    <div class="section-title">OBSERVAÇÕES</div>
    <div class="problem-box">
      <%= ordemServico.observacoes %>
    </div>
  </div>
  <% } %>

  <div class="signature-area">
    <div class="signature-box">
      <div class="signature-line">Responsável Técnico</div>
    </div>
    <div class="signature-box">
      <div class="signature-line">Cliente</div>
    </div>
  </div>

  <div class="footer">
    <p>Tecle Motos - Motos e Scooters Elétricas</p>
    <p>Documento gerado em <%= new Date().toLocaleString('pt-BR') %></p>
  </div>
</body>
</html>
