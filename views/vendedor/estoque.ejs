<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Consulta de Estoque - Tecle Motos</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/topbar') %>
      <div class="content">
        <div class="page-header">
          <h1 class="page-title">Consulta de Estoque</h1>
        </div>

        <form class="search-bar" method="GET">
          <input type="text" name="search" class="form-control" placeholder="Pesquisar produto..." value="<%= search || '' %>">
          <button type="submit" class="btn btn-secondary"><i class="fas fa-search"></i></button>
        </form>

        <div class="card">
          <div class="card-body">
            <div class="table-container">
              <table>
                <thead>
                  <tr>
                    <th>Produto</th>
                    <th>Tipo</th>
                    <th>Modelo/Cor</th>
                    <th>Estoque</th>
                    <th>Subestoque</th>
                    <th>Quantidade</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (itensEstoque.length === 0) { %>
                    <tr><td colspan="7" class="empty-state">Nenhum item encontrado</td></tr>
                  <% } else { %>
                    <% itensEstoque.forEach(item => { %>
                      <tr>
                        <td><strong><%= item.Produto ? (item.Produto.nome_modelo || item.Produto.nome_produto) : '-' %></strong></td>
                        <td>
                          <span class="badge badge-<%= item.Produto && (item.Produto.tipo === 'MOTO' || item.Produto.tipo === 'SCOOTER') ? 'success' : 'info' %>">
                            <%= item.Produto ? item.Produto.tipo : '-' %>
                          </span>
                        </td>
                        <td><%= item.Produto ? (item.Produto.cor || '-') : '-' %></td>
                        <td><%= item.Estoque ? item.Estoque.nome_estoque : '-' %></td>
                        <td><%= item.Subestoque ? item.Subestoque.nome_subestoque : '-' %></td>
                        <td><strong><%= item.quantidade %></strong></td>
                        <td>
                          <span class="badge badge-<%= item.quantidade <= item.quantidade_minima ? 'danger' : (item.quantidade <= item.quantidade_minima * 2 ? 'warning' : 'success') %>">
                            <%= item.quantidade <= item.quantidade_minima ? 'BAIXO' : (item.quantidade <= item.quantidade_minima * 2 ? 'MÉDIO' : 'OK') %>
                          </span>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
